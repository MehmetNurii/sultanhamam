---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { supabase } from "../../lib/supabase";

// Generate static paths for all services
export async function getStaticPaths() {
    const { data: services, error } = await supabase
        .from("services")
        .select("slug")
        .eq("visible", true)
        .order("sort_order");

    if (error) {
        console.error("Error fetching services:", error);
        return [];
    }

    return services.map((service) => ({
        params: { slug: service.slug },
    }));
}

// Get the current service slug from params
const { slug } = Astro.params;

// Fetch service details
const { data: service, error: serviceError } = await supabase
    .from("services")
    .select("*")
    .eq("slug", slug)
    .eq("visible", true)
    .single();

if (serviceError || !service) {
    return Astro.redirect("/404");
}

// Fetch FAQs for this service
const { data: faqs, error: faqsError } = await supabase
    .from("service_faqs")
    .select("*")
    .eq("service_id", service.id)
    .order("sort_order");

const serviceFaqs = faqsError ? [] : faqs;

// Parse sidebar links from JSONB
const sidebarLinks = service.sidebar_links || [];

// Fetch team members from page_sections (index page team section)
const { data: teamSection, error: teamError } = await supabase
    .from("page_sections")
    .select("extra_data")
    .eq("page_slug", "index")
    .eq("section_key", "team")
    .single();

const teamMembers =
    !teamError && teamSection?.extra_data?.team_members
        ? teamSection.extra_data.team_members
        : [];

// Set default FAQ state (for accordion) - index 1 (second FAQ)
const defaultOpenFaqIndex = serviceFaqs.length > 1 ? 1 : 0;
