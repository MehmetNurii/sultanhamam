        <script is:inline>
            // FAQ Toggle functionality
            document.addEventListener("DOMContentLoaded", function () {
                const toggleTitles = document.querySelectorAll(
                    ".elementor-widget-cmsmasters-toggles__title",
                );

                toggleTitles.forEach((title) => {
                    title.addEventListener("click", function (e) {
                        e.preventDefault();

                        const parent = this.closest(
                            ".elementor-widget-cmsmasters-toggles__item",
                        );
                        const content = parent.querySelector(
                            ".elementor-widget-cmsmasters-toggles__content",
                        );
                        const isActive =
                            this.classList.contains("active-toggle");

                        // Toggle active class
                        this.classList.toggle("active-toggle");
                        parent.classList.toggle("active-toggle");
                        content.classList.toggle("active-toggle");

                        // Toggle display
                        if (isActive) {
                            content.style.display = "none";
                            content.setAttribute("hidden", "");
                        } else {
                            content.style.display = "block";
                            content.removeAttribute("hidden");
                        }
                    });
                });
            });
        </script>
