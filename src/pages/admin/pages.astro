---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getPages, updatePage } from '../../lib/supabase';

const pages = await getPages();

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  
  if (action === 'update') {
    const id = parseInt(formData.get('id') as string);
    const updates = {
      title: formData.get('title') as string,
      meta_title: formData.get('meta_title') as string,
      meta_description: formData.get('meta_description') as string,
      visible: formData.get('visible') === 'true'
    };
    
    await updatePage(id, updates);
    return Astro.redirect('/admin/pages?updated=true');
  }
}

const updated = Astro.url.searchParams.get('updated');
---

<AdminLayout title="Sayfa Yönetimi" currentPage="pages">
  <!-- Success Message -->
  {updated && (
    <div class="admin-alert admin-alert-success admin-mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>Sayfa başarıyla güncellendi!</span>
    </div>
  )}

  <!-- Page Header -->
  <div class="admin-flex admin-items-center admin-justify-between admin-mb-6">
    <div>
      <p class="admin-text-muted">Sitenizdeki tüm sayfaları buradan yönetebilirsiniz. Veriler Supabase'den geliyor.</p>
    </div>
  </div>
  
  <!-- Pages Table -->
  <div class="admin-card">
    <div class="admin-card-header">
      <h3 class="admin-card-title">Tüm Sayfalar ({pages.length})</h3>
      <span class="admin-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
        Supabase
      </span>
    </div>
    <div class="admin-card-body" style="padding: 0;">
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width: 50px;">#</th>
              <th>Sayfa Adı</th>
              <th>Slug</th>
              <th>Meta Başlık</th>
              <th>Durum</th>
              <th>Güncelleme</th>
              <th style="width: 120px;">İşlemler</th>
            </tr>
          </thead>
          <tbody>
            {pages.map((page, index) => (
              <tr data-page-id={page.id}>
                <td class="admin-text-muted">{index + 1}</td>
                <td>
                  <strong>{page.title}</strong>
                </td>
                <td>
                  <code style="background: var(--admin-bg-secondary); padding: 4px 8px; border-radius: 4px; font-size: 0.75rem;">
                    /{page.slug === 'index' ? '' : page.slug}
                  </code>
                </td>
                <td class="admin-text-muted admin-text-sm" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {page.meta_title}
                </td>
                <td>
                  <span class={`admin-table-status ${page.visible ? 'active' : 'hidden'}`}>
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span>
                    {page.visible ? 'Aktif' : 'Gizli'}
                  </span>
                </td>
                <td class="admin-text-muted admin-text-sm">{new Date(page.updated_at).toLocaleDateString('tr-TR')}</td>
                <td>
                  <div class="admin-flex admin-gap-2">
                    <button 
                      class="admin-btn admin-btn-secondary admin-btn-icon admin-btn-sm" 
                      title="Düzenle" 
                      onclick={`openEditModal(${JSON.stringify(page)})`}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    </button>
                    <a href={`/${page.slug === 'index' ? '' : page.slug}`} target="_blank" class="admin-btn admin-btn-secondary admin-btn-icon admin-btn-sm" title="Görüntüle">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<style is:inline>
  .admin-alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: var(--admin-radius-md);
    font-size: 0.875rem;
  }
  
  .admin-alert-success {
    background: rgba(16, 185, 129, 0.15);
    color: var(--admin-success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }
  
  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(124, 58, 237, 0.2);
    color: var(--admin-accent-secondary);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .admin-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
  }
  
  .admin-modal-overlay.active {
    display: flex;
  }
  
  .admin-modal {
    background: var(--admin-bg-card);
    border: 1px solid var(--admin-border-color);
    border-radius: var(--admin-radius-lg);
    width: 100%;
    max-width: 500px;
    max-height: 90vh;
    overflow-y: auto;
  }
  
  .admin-modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--admin-border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .admin-modal-title {
    font-size: 1.125rem;
    font-weight: 600;
  }
  
  .admin-modal-close {
    background: none;
    border: none;
    color: var(--admin-text-muted);
    cursor: pointer;
    padding: 4px;
  }
  
  .admin-modal-body {
    padding: 24px;
  }
  
  .admin-modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--admin-border-color);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }
</style>

<!-- Edit Modal -->
<div id="editModal" class="admin-modal-overlay">
  <div class="admin-modal">
    <div class="admin-modal-header">
      <h3 class="admin-modal-title">Sayfa Düzenle</h3>
      <button class="admin-modal-close" onclick="closeEditModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <form method="POST">
      <input type="hidden" name="action" value="update">
      <input type="hidden" id="pageId" name="id">
      
      <div class="admin-modal-body">
        <div class="admin-form-group">
          <label class="admin-form-label" for="pageTitle">Sayfa Başlığı</label>
          <input type="text" id="pageTitle" name="title" class="admin-form-input" placeholder="Sayfa başlığı" required>
        </div>
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="metaTitle">Meta Başlık (SEO)</label>
          <input type="text" id="metaTitle" name="meta_title" class="admin-form-input" placeholder="Tarayıcı sekmesinde görünecek başlık">
        </div>
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="metaDescription">Meta Açıklama (SEO)</label>
          <textarea id="metaDescription" name="meta_description" class="admin-form-textarea" placeholder="Arama motorlarında görünecek açıklama"></textarea>
        </div>
        
        <div class="admin-form-group">
          <div class="admin-flex admin-items-center admin-justify-between">
            <label class="admin-form-label" style="margin-bottom: 0;">Sayfa Görünür</label>
            <label class="admin-toggle">
              <input type="checkbox" id="pageVisible" name="visible" value="true" checked>
              <span class="admin-toggle-slider"></span>
            </label>
          </div>
          <input type="hidden" id="visibleHidden" name="visible" value="false">
        </div>
      </div>
      
      <div class="admin-modal-footer">
        <button type="button" class="admin-btn admin-btn-secondary" onclick="closeEditModal()">İptal</button>
        <button type="submit" class="admin-btn admin-btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Kaydet
        </button>
      </div>
    </form>
  </div>
</div>

<script is:inline>
  function openEditModal(page) {
    document.getElementById('pageId').value = page.id;
    document.getElementById('pageTitle').value = page.title;
    document.getElementById('metaTitle').value = page.meta_title || '';
    document.getElementById('metaDescription').value = page.meta_description || '';
    document.getElementById('pageVisible').checked = page.visible;
    
    // Update hidden field based on checkbox
    updateVisibleField();
    
    document.getElementById('editModal').classList.add('active');
  }
  
  function closeEditModal() {
    document.getElementById('editModal').classList.remove('active');
  }
  
  function updateVisibleField() {
    const checkbox = document.getElementById('pageVisible');
    const hidden = document.getElementById('visibleHidden');
    hidden.disabled = checkbox.checked;
  }
  
  // Update visible field when checkbox changes
  document.getElementById('pageVisible').addEventListener('change', updateVisibleField);
  
  // Close modal on outside click
  document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeEditModal();
    }
  });
  
  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeEditModal();
    }
  });
</script>
