---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSiteSettings, updateSiteSetting } from '../../lib/supabase';

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const section = formData.get('section');
  
  if (section === 'site') {
    await updateSiteSetting('site_title', formData.get('site_title') as string);
    await updateSiteSetting('site_description', formData.get('site_description') as string);
  }
  
  if (section === 'contact') {
    await updateSiteSetting('phone', formData.get('phone') as string);
    await updateSiteSetting('email', formData.get('email') as string);
    await updateSiteSetting('address', formData.get('address') as string);
  }
  
  if (section === 'social') {
    await updateSiteSetting('facebook', formData.get('facebook') as string);
    await updateSiteSetting('instagram', formData.get('instagram') as string);
    await updateSiteSetting('twitter', formData.get('twitter') as string);
  }
  
  if (section === 'hero') {
    await updateSiteSetting('hero_title', formData.get('hero_title') as string);
    await updateSiteSetting('hero_subtitle', formData.get('hero_subtitle') as string);
  }
  
  return Astro.redirect('/admin/content?updated=' + section);
}

const settings = await getSiteSettings();
const updated = Astro.url.searchParams.get('updated');

const sectionNames: Record<string, string> = {
  site: 'Site bilgileri',
  contact: 'İletişim bilgileri',
  social: 'Sosyal medya bilgileri',
  hero: 'Hero metinleri'
};
---

<AdminLayout title="İçerik Yönetimi" currentPage="content">
  <!-- Success Message -->
  {updated && (
    <div class="admin-alert admin-alert-success admin-mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>{sectionNames[updated] || 'Ayarlar'} başarıyla güncellendi!</span>
    </div>
  )}

  <!-- Page Header -->
  <div class="admin-flex admin-items-center admin-justify-between admin-mb-6">
    <div>
      <p class="admin-text-muted">Site genelinde kullanılan içerik ve iletişim bilgilerini düzenleyin. Değişiklikler Supabase'e kaydedilir.</p>
    </div>
    <span class="admin-badge">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
      </svg>
      Supabase
    </span>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px;">
    <!-- Site Info Card -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h3 class="admin-card-title">Site Bilgileri</h3>
      </div>
      <div class="admin-card-body">
        <form method="POST">
          <input type="hidden" name="section" value="site">
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="siteTitle">Site Başlığı</label>
            <input type="text" id="siteTitle" name="site_title" class="admin-form-input" value={settings.site_title || ''}>
          </div>
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="siteDescription">Site Açıklaması</label>
            <textarea id="siteDescription" name="site_description" class="admin-form-textarea">{settings.site_description || ''}</textarea>
          </div>
          
          <button type="submit" class="admin-btn admin-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Kaydet
          </button>
        </form>
      </div>
    </div>
    
    <!-- Contact Info Card -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h3 class="admin-card-title">İletişim Bilgileri</h3>
      </div>
      <div class="admin-card-body">
        <form method="POST">
          <input type="hidden" name="section" value="contact">
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="phone">Telefon</label>
            <input type="tel" id="phone" name="phone" class="admin-form-input" value={settings.phone || ''}>
          </div>
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="email">E-posta</label>
            <input type="email" id="email" name="email" class="admin-form-input" value={settings.email || ''}>
          </div>
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="address">Adres</label>
            <textarea id="address" name="address" class="admin-form-textarea" style="min-height: 80px;">{settings.address || ''}</textarea>
          </div>
          
          <button type="submit" class="admin-btn admin-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Kaydet
          </button>
        </form>
      </div>
    </div>
    
    <!-- Social Media Card -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h3 class="admin-card-title">Sosyal Medya</h3>
      </div>
      <div class="admin-card-body">
        <form method="POST">
          <input type="hidden" name="section" value="social">
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="facebook">
              <span style="display: flex; align-items: center; gap: 8px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </span>
            </label>
            <input type="url" id="facebook" name="facebook" class="admin-form-input" value={settings.facebook || ''} placeholder="https://facebook.com/...">
          </div>
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="instagram">
              <span style="display: flex; align-items: center; gap: 8px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                Instagram
              </span>
            </label>
            <input type="url" id="instagram" name="instagram" class="admin-form-input" value={settings.instagram || ''} placeholder="https://instagram.com/...">
          </div>
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="twitter">
              <span style="display: flex; align-items: center; gap: 8px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                Twitter (X)
              </span>
            </label>
            <input type="url" id="twitter" name="twitter" class="admin-form-input" value={settings.twitter || ''} placeholder="https://twitter.com/...">
          </div>
          
          <button type="submit" class="admin-btn admin-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Kaydet
          </button>
        </form>
      </div>
    </div>
    
    <!-- Hero Texts -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h3 class="admin-card-title">Hero Metinleri</h3>
      </div>
      <div class="admin-card-body">
        <form method="POST">
          <input type="hidden" name="section" value="hero">
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="heroTitle">Ana Sayfa Başlığı</label>
            <input type="text" id="heroTitle" name="hero_title" class="admin-form-input" value={settings.hero_title || ''}>
          </div>
          
          <div class="admin-form-group">
            <label class="admin-form-label" for="heroSubtitle">Ana Sayfa Alt Başlığı</label>
            <textarea id="heroSubtitle" name="hero_subtitle" class="admin-form-textarea">{settings.hero_subtitle || ''}</textarea>
          </div>
          
          <button type="submit" class="admin-btn admin-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Kaydet
          </button>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<style is:inline>
  .admin-alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: var(--admin-radius-md);
    font-size: 0.875rem;
  }
  
  .admin-alert-success {
    background: rgba(16, 185, 129, 0.15);
    color: var(--admin-success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }
  
  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(124, 58, 237, 0.2);
    color: var(--admin-accent-secondary);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }
</style>
