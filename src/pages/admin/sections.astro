---
import AdminLayout from "../../layouts/AdminLayout.astro";
import {
  getAllPageSections,
  updatePageSection,
  getPages,
} from "../../lib/supabase";

const sections = await getAllPageSections();
const pages = await getPages();

// Handle form submission
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action");

  if (action === "update") {
    const id = parseInt(formData.get("id") as string);
    const updates = {
      title: (formData.get("title") as string) || null,
      subtitle: (formData.get("subtitle") as string) || null,
      description: (formData.get("description") as string) || null,
      button_text: (formData.get("button_text") as string) || null,
      button_url: (formData.get("button_url") as string) || null,
      image_url: (formData.get("image_url") as string) || null,
      visible: formData.get("visible") === "true",
    };

    await updatePageSection(id, updates);
    return Astro.redirect("/admin/sections?updated=true");
  }
}

const updated = Astro.url.searchParams.get("updated");

// Group sections by page
const sectionsByPage = sections.reduce(
  (acc, section) => {
    if (!acc[section.page_slug]) {
      acc[section.page_slug] = [];
    }
    acc[section.page_slug].push(section);
    return acc;
  },
  {} as Record<string, typeof sections>,
);

// Get page titles
const pageTitles = pages.reduce(
  (acc, page) => {
    acc[page.slug] = page.title;
    return acc;
  },
  {} as Record<string, string>,
);
---

<AdminLayout title="Sayfa Bölümleri" currentPage="sections">
  <!-- Success Message -->
  {
    updated && (
      <div class="admin-alert admin-alert-success admin-mb-6">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
          />
        </svg>
        <span>Bölüm başarıyla güncellendi!</span>
      </div>
    )
  }

  <!-- Page Header -->
  <div class="admin-flex admin-items-center admin-justify-between admin-mb-6">
    <div>
      <p class="admin-text-muted">
        Her sayfanın bölümlerini (Hero, CTA, vb.) buradan düzenleyebilirsiniz.
      </p>
    </div>
  </div>

  {
    sections.length === 0 ? (
      <div class="admin-card">
        <div
          class="admin-card-body"
          style="text-align: center; padding: 60px 20px;"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            style="margin: 0 auto 16px; opacity: 0.5;"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
            />
          </svg>
          <h3 style="margin-bottom: 8px;">Henüz Bölüm Yok</h3>
          <p class="admin-text-muted">
            Supabase'de <code>page_sections</code> tablosunu oluşturun ve
            verileri ekleyin.
          </p>
          <p class="admin-text-muted admin-text-sm" style="margin-top: 8px;">
            SQL dosyası: <code>supabase/page_sections.sql</code>
          </p>
        </div>
      </div>
    ) : (
      Object.entries(sectionsByPage).map(([pageSlug, pageSections]) => (
        <div class="admin-card admin-mb-6">
          <div class="admin-card-header">
            <h3 class="admin-card-title">
              {pageTitles[pageSlug] || pageSlug}
              <span
                class="admin-text-muted admin-text-sm"
                style="font-weight: normal; margin-left: 8px;"
              >
                /{pageSlug === "index" ? "" : pageSlug}
              </span>
            </h3>
            <span class="admin-badge">{pageSections.length} bölüm</span>
          </div>
          <div class="admin-card-body" style="padding: 0;">
            <div class="sections-grid">
              {pageSections.map((section) => (
                <div class="section-item">
                  <div class="section-header">
                    <span class="section-type">
                      {section.section_type.toUpperCase()}
                    </span>
                    <span
                      class={`section-status ${section.visible ? "active" : "hidden"}`}
                    >
                      {section.visible ? "Görünür" : "Gizli"}
                    </span>
                  </div>
                  <h4 class="section-title">
                    {section.title || "(Başlık yok)"}
                  </h4>
                  {section.subtitle && (
                    <p class="section-subtitle">{section.subtitle}</p>
                  )}
                  {section.description && (
                    <p class="section-description">
                      {section.description.substring(0, 100)}
                      {section.description.length > 100 ? "..." : ""}
                    </p>
                  )}
                  {(section.button_text || section.image_url) && (
                    <div class="section-button-preview">
                      {section.button_text && (
                        <span class="button-preview">
                          {section.button_text}
                        </span>
                      )}
                      {section.image_url && (
                        <span
                          class="button-url"
                          style="color: var(--admin-accent);"
                        >
                          Resim Var
                        </span>
                      )}
                    </div>
                  )}
                  <div class="section-actions">
                    <button
                      class="admin-btn admin-btn-primary admin-btn-sm"
                      onclick={`openEditModal(${JSON.stringify(section)})`}
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                        />
                      </svg>
                      Düzenle
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))
    )
  }
</AdminLayout>

<style is:inline>
  .admin-alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: var(--admin-radius-md);
    font-size: 0.875rem;
  }

  .admin-alert-success {
    background: rgba(16, 185, 129, 0.15);
    color: var(--admin-success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(124, 58, 237, 0.2);
    color: var(--admin-accent-secondary);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--admin-border-color);
  }

  .section-item {
    background: var(--admin-bg-card);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .section-type {
    background: rgba(59, 130, 246, 0.15);
    color: var(--admin-accent);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .section-status {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 9999px;
  }

  .section-status.active {
    background: rgba(16, 185, 129, 0.15);
    color: var(--admin-success);
  }

  .section-status.hidden {
    background: rgba(239, 68, 68, 0.15);
    color: var(--admin-danger);
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--admin-text);
  }

  .section-subtitle {
    font-size: 0.8rem;
    color: var(--admin-accent);
    margin: 0;
  }

  .section-description {
    font-size: 0.8rem;
    color: var(--admin-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .section-button-preview {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .button-preview {
    background: var(--admin-accent);
    color: white;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.75rem;
  }

  .button-url {
    font-size: 0.7rem;
    color: var(--admin-text-muted);
  }

  .section-actions {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--admin-border-color);
  }

  /* Modal Styles */
  .admin-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
  }

  .admin-modal-overlay.active {
    display: flex;
  }

  .admin-modal {
    background: var(--admin-bg-card);
    border: 1px solid var(--admin-border-color);
    border-radius: var(--admin-radius-lg);
    width: 100%;
    max-width: 600px;
    max-height: 90vh;
    overflow-y: auto;
  }

  .admin-modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--admin-border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .admin-modal-title {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .admin-modal-close {
    background: none;
    border: none;
    color: var(--admin-text-muted);
    cursor: pointer;
    padding: 4px;
  }

  .admin-modal-body {
    padding: 24px;
  }

  .admin-modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--admin-border-color);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }
</style>

<!-- Edit Modal -->
<div id="editModal" class="admin-modal-overlay">
  <div class="admin-modal">
    <div class="admin-modal-header">
      <h3 class="admin-modal-title">Bölüm Düzenle</h3>
      <button class="admin-modal-close" onclick="closeEditModal()">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <form method="POST">
      <input type="hidden" name="action" value="update" />
      <input type="hidden" id="sectionId" name="id" />

      <div class="admin-modal-body">
        <div class="admin-form-group">
          <label class="admin-form-label" for="sectionTitle">Başlık</label>
          <input
            type="text"
            id="sectionTitle"
            name="title"
            class="admin-form-input"
            placeholder="Ana başlık"
          />
        </div>

        <div class="admin-form-group">
          <label class="admin-form-label" for="sectionSubtitle"
            >Alt Başlık</label
          >
          <input
            type="text"
            id="sectionSubtitle"
            name="subtitle"
            class="admin-form-input"
            placeholder="Alt başlık veya etiket"
          />
        </div>

        <div class="admin-form-group">
          <label class="admin-form-label" for="sectionDescription"
            >Açıklama</label
          >
          <textarea
            id="sectionDescription"
            name="description"
            class="admin-form-textarea"
            rows="4"
            placeholder="Bölüm açıklaması"></textarea>
        </div>

        <div class="admin-form-group">
          <label class="admin-form-label" for="sectionImage">Resim URL</label>
          <input
            type="text"
            id="sectionImage"
            name="image_url"
            class="admin-form-input"
            placeholder="/assets/image.jpg veya https://..."
          />
          <p class="admin-text-muted admin-text-sm" style="margin-top: 4px;">
            Arka plan veya içerik resmi
          </p>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div class="admin-form-group">
            <label class="admin-form-label" for="buttonText">Buton Metni</label>
            <input
              type="text"
              id="buttonText"
              name="button_text"
              class="admin-form-input"
              placeholder="Örn: Daha Fazla"
            />
          </div>

          <div class="admin-form-group">
            <label class="admin-form-label" for="buttonUrl">Buton URL</label>
            <input
              type="text"
              id="buttonUrl"
              name="button_url"
              class="admin-form-input"
              placeholder="Örn: /hakkimizda"
            />
          </div>
        </div>

        <div class="admin-form-group">
          <div class="admin-flex admin-items-center admin-justify-between">
            <label class="admin-form-label" style="margin-bottom: 0;"
              >Görünür</label
            >
            <label class="admin-toggle">
              <input
                type="checkbox"
                id="sectionVisible"
                name="visible"
                value="true"
                checked
              />
              <span class="admin-toggle-slider"></span>
            </label>
          </div>
          <input
            type="hidden"
            id="visibleHidden"
            name="visible"
            value="false"
          />
        </div>
      </div>

      <div class="admin-modal-footer">
        <button
          type="button"
          class="admin-btn admin-btn-secondary"
          onclick="closeEditModal()">İptal</button
        >
        <button type="submit" class="admin-btn admin-btn-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"></path>
          </svg>
          Kaydet
        </button>
      </div>
    </form>
  </div>
</div>

<script is:inline>
  function openEditModal(section) {
    document.getElementById("sectionId").value = section.id;
    document.getElementById("sectionTitle").value = section.title || "";
    document.getElementById("sectionSubtitle").value = section.subtitle || "";
    document.getElementById("sectionDescription").value =
      section.description || "";
    document.getElementById("sectionImage").value = section.image_url || "";
    document.getElementById("buttonText").value = section.button_text || "";
    document.getElementById("buttonUrl").value = section.button_url || "";
    document.getElementById("sectionVisible").checked = section.visible;

    updateVisibleField();

    document.getElementById("editModal").classList.add("active");
  }

  function closeEditModal() {
    document.getElementById("editModal").classList.remove("active");
  }

  function updateVisibleField() {
    const checkbox = document.getElementById("sectionVisible");
    const hidden = document.getElementById("visibleHidden");
    hidden.disabled = checkbox.checked;
  }

  document
    .getElementById("sectionVisible")
    .addEventListener("change", updateVisibleField);

  document.getElementById("editModal").addEventListener("click", function (e) {
    if (e.target === this) {
      closeEditModal();
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      closeEditModal();
    }
  });
</script>
