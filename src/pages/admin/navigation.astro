---
import AdminLayout from '../../layouts/AdminLayout.astro';
import siteData from '../../content/data.json';

const navItems = siteData.navigation.main.sort((a, b) => a.order - b.order);
---

<AdminLayout title="Navigasyon Yönetimi" currentPage="navigation">
  <!-- Page Header -->
  <div class="admin-flex admin-items-center admin-justify-between admin-mb-6">
    <div>
      <p class="admin-text-muted">Site menü öğelerini buradan yönetebilirsiniz. Sıralamayı değiştirmek için öğeleri sürükleyip bırakın.</p>
    </div>
  </div>
  
  <!-- Navigation Items -->
  <div class="admin-card">
    <div class="admin-card-header">
      <h3 class="admin-card-title">Ana Menü ({navItems.length} öğe)</h3>
      <button class="admin-btn admin-btn-primary admin-btn-sm" onclick="openAddModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Yeni Öğe Ekle
      </button>
    </div>
    <div class="admin-card-body" style="padding: 0;">
      <ul class="admin-list" id="navList">
        {navItems.map((item, index) => (
          <li class="admin-list-item" data-id={item.id} data-order={item.order}>
            <div class="admin-flex admin-items-center admin-gap-4" style="flex: 1;">
              <!-- Drag Handle -->
              <div class="admin-drag-handle" title="Sıralamayı değiştirmek için sürükleyin">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
                </svg>
              </div>
              
              <!-- Order Number -->
              <span class="admin-text-muted" style="width: 24px; text-align: center;">{index + 1}</span>
              
              <!-- Title -->
              <div style="flex: 1;">
                <strong>{item.title}</strong>
                <div class="admin-text-muted admin-text-sm">{item.url}</div>
              </div>
              
              <!-- Status -->
              <span class={`admin-table-status ${item.visible ? 'active' : 'hidden'}`}>
                <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span>
                {item.visible ? 'Görünür' : 'Gizli'}
              </span>
            </div>
            
            <!-- Actions -->
            <div class="admin-flex admin-gap-2">
              <button class="admin-btn admin-btn-secondary admin-btn-icon admin-btn-sm" title="Düzenle" onclick={`openEditNavModal(${item.id})`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </button>
              <button class="admin-btn admin-btn-secondary admin-btn-icon admin-btn-sm" title="Sil" onclick={`deleteNavItem(${item.id})`} style="color: var(--admin-danger);">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
  
  <!-- Info Card -->
  <div class="admin-card" style="margin-top: 24px;">
    <div class="admin-card-body">
      <div class="admin-flex admin-items-center admin-gap-4">
        <div class="admin-stat-icon green">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h4 style="margin-bottom: 4px;">Navigasyon İpuçları</h4>
          <p class="admin-text-muted admin-text-sm">
            • Menü öğelerini sürükleyerek sıralamayı değiştirebilirsiniz.<br>
            • Gizli menü öğeleri sitede görüntülenmez ancak sayfa hâlâ erişilebilir olur.<br>
            • Değişikliklerin yansıması için sitenin yeniden derlenmesi gerekir.
          </p>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style is:inline>
  /* Modal Styles */
  .admin-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
  }
  
  .admin-modal-overlay.active {
    display: flex;
  }
  
  .admin-modal {
    background: var(--admin-bg-card);
    border: 1px solid var(--admin-border-color);
    border-radius: var(--admin-radius-lg);
    width: 100%;
    max-width: 500px;
    max-height: 90vh;
    overflow-y: auto;
  }
  
  .admin-modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--admin-border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .admin-modal-title {
    font-size: 1.125rem;
    font-weight: 600;
  }
  
  .admin-modal-close {
    background: none;
    border: none;
    color: var(--admin-text-muted);
    cursor: pointer;
    padding: 4px;
  }
  
  .admin-modal-close:hover {
    color: var(--admin-text-primary);
  }
  
  .admin-modal-body {
    padding: 24px;
  }
  
  .admin-modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--admin-border-color);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }
  
  .admin-list-item {
    cursor: move;
  }
  
  .admin-list-item.dragging {
    opacity: 0.5;
    background: var(--admin-bg-hover);
  }
</style>

<!-- Edit Modal -->
<div id="editNavModal" class="admin-modal-overlay">
  <div class="admin-modal">
    <div class="admin-modal-header">
      <h3 class="admin-modal-title" id="navModalTitle">Menü Öğesi Düzenle</h3>
      <button class="admin-modal-close" onclick="closeNavModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="admin-modal-body">
      <form id="editNavForm">
        <input type="hidden" id="navId" name="id">
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="navTitle">Menü Başlığı</label>
          <input type="text" id="navTitle" name="title" class="admin-form-input" placeholder="Menüde görünecek başlık">
        </div>
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="navUrl">URL</label>
          <input type="text" id="navUrl" name="url" class="admin-form-input" placeholder="/sayfa-adi">
        </div>
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="navOrder">Sıra Numarası</label>
          <input type="number" id="navOrder" name="order" class="admin-form-input" placeholder="1" min="1">
        </div>
        
        <div class="admin-form-group">
          <div class="admin-flex admin-items-center admin-justify-between">
            <label class="admin-form-label" style="margin-bottom: 0;">Menüde Görünsün</label>
            <label class="admin-toggle">
              <input type="checkbox" id="navVisible" name="visible" checked>
              <span class="admin-toggle-slider"></span>
            </label>
          </div>
        </div>
      </form>
    </div>
    <div class="admin-modal-footer">
      <button type="button" class="admin-btn admin-btn-secondary" onclick="closeNavModal()">İptal</button>
      <button type="button" class="admin-btn admin-btn-primary" onclick="saveNavChanges()">Kaydet</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ navItems }}>
  // Nav data from server
  let navData = navItems;
  let isAddMode = false;
  
  function openEditNavModal(navId) {
    isAddMode = false;
    const item = navData.find(n => n.id === navId);
    if (!item) return;
    
    document.getElementById('navModalTitle').textContent = 'Menü Öğesi Düzenle';
    document.getElementById('navId').value = item.id;
    document.getElementById('navTitle').value = item.title;
    document.getElementById('navUrl').value = item.url;
    document.getElementById('navOrder').value = item.order;
    document.getElementById('navVisible').checked = item.visible;
    
    document.getElementById('editNavModal').classList.add('active');
  }
  
  function openAddModal() {
    isAddMode = true;
    const newOrder = Math.max(...navData.map(n => n.order)) + 1;
    
    document.getElementById('navModalTitle').textContent = 'Yeni Menü Öğesi Ekle';
    document.getElementById('navId').value = '';
    document.getElementById('navTitle').value = '';
    document.getElementById('navUrl').value = '/';
    document.getElementById('navOrder').value = newOrder;
    document.getElementById('navVisible').checked = true;
    
    document.getElementById('editNavModal').classList.add('active');
  }
  
  function closeNavModal() {
    document.getElementById('editNavModal').classList.remove('active');
  }
  
  function saveNavChanges() {
    const formData = {
      id: isAddMode ? Math.max(...navData.map(n => n.id)) + 1 : parseInt(document.getElementById('navId').value),
      title: document.getElementById('navTitle').value,
      url: document.getElementById('navUrl').value,
      order: parseInt(document.getElementById('navOrder').value),
      visible: document.getElementById('navVisible').checked
    };
    
    // In a real app, this would send to an API
    alert('Değişiklikler kaydedildi!\n\nNot: Bu demo versiyonunda değişiklikler kalıcı olarak kaydedilmez. Gerçek uygulamada bir API endpoint\'e gönderilir ve data.json dosyası güncellenir.');
    
    closeNavModal();
  }
  
  function deleteNavItem(navId) {
    const item = navData.find(n => n.id === navId);
    if (!item) return;
    
    if (confirm(`"${item.title}" menü öğesini silmek istediğinize emin misiniz?`)) {
      alert('Öğe silindi!\n\nNot: Bu demo versiyonunda değişiklikler kalıcı değildir.');
    }
  }
  
  // Close modal on outside click
  document.getElementById('editNavModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeNavModal();
    }
  });
  
  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeNavModal();
    }
  });
  
  // Simple drag and drop for reordering (visual only in demo)
  const list = document.getElementById('navList');
  let dragItem = null;
  
  list.querySelectorAll('.admin-list-item').forEach(item => {
    item.setAttribute('draggable', 'true');
    
    item.addEventListener('dragstart', function(e) {
      dragItem = this;
      setTimeout(() => this.classList.add('dragging'), 0);
    });
    
    item.addEventListener('dragend', function() {
      this.classList.remove('dragging');
      dragItem = null;
    });
    
    item.addEventListener('dragover', function(e) {
      e.preventDefault();
      if (dragItem && dragItem !== this) {
        const rect = this.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        if (e.clientY < midY) {
          list.insertBefore(dragItem, this);
        } else {
          list.insertBefore(dragItem, this.nextSibling);
        }
      }
    });
  });
</script>
