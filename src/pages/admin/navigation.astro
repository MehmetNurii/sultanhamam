---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getNavigation, updateNavItem, createNavItem, deleteNavItem } from '../../lib/supabase';

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  
  if (action === 'update') {
    const id = parseInt(formData.get('id') as string);
    const updates = {
      title: formData.get('title') as string,
      url: formData.get('url') as string,
      sort_order: parseInt(formData.get('sort_order') as string),
      visible: formData.get('visible') === 'true'
    };
    
    await updateNavItem(id, updates);
    return Astro.redirect('/admin/navigation?updated=true');
  }
  
  if (action === 'create') {
    const item = {
      title: formData.get('title') as string,
      url: formData.get('url') as string,
      sort_order: parseInt(formData.get('sort_order') as string),
      visible: formData.get('visible') === 'true'
    };
    
    await createNavItem(item);
    return Astro.redirect('/admin/navigation?created=true');
  }
  
  if (action === 'delete') {
    const id = parseInt(formData.get('id') as string);
    await deleteNavItem(id);
    return Astro.redirect('/admin/navigation?deleted=true');
  }
}

const navItems = await getNavigation();

const updated = Astro.url.searchParams.get('updated');
const created = Astro.url.searchParams.get('created');
const deleted = Astro.url.searchParams.get('deleted');
---

<AdminLayout title="Navigasyon Yönetimi" currentPage="navigation">
  <!-- Success Messages -->
  {updated && (
    <div class="admin-alert admin-alert-success admin-mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>Menü öğesi başarıyla güncellendi!</span>
    </div>
  )}
  
  {created && (
    <div class="admin-alert admin-alert-success admin-mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <span>Yeni menü öğesi başarıyla eklendi!</span>
    </div>
  )}
  
  {deleted && (
    <div class="admin-alert admin-alert-warning admin-mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      <span>Menü öğesi silindi!</span>
    </div>
  )}

  <!-- Page Header -->
  <div class="admin-flex admin-items-center admin-justify-between admin-mb-6">
    <div>
      <p class="admin-text-muted">Site menü öğelerini buradan yönetebilirsiniz. Değişiklikler Supabase'e kaydedilir.</p>
    </div>
  </div>
  
  <!-- Navigation Items -->
  <div class="admin-card">
    <div class="admin-card-header">
      <div class="admin-flex admin-items-center admin-gap-4">
        <h3 class="admin-card-title">Ana Menü ({navItems.length} öğe)</h3>
        <span class="admin-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          Supabase
        </span>
      </div>
      <button class="admin-btn admin-btn-primary admin-btn-sm" onclick="openAddModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Yeni Öğe Ekle
      </button>
    </div>
    <div class="admin-card-body" style="padding: 0;">
      <ul class="admin-list" id="navList">
        {navItems.map((item, index) => (
          <li class="admin-list-item" data-id={item.id}>
            <div class="admin-flex admin-items-center admin-gap-4" style="flex: 1;">
              <!-- Order Number -->
              <span class="admin-text-muted" style="width: 24px; text-align: center;">{item.sort_order}</span>
              
              <!-- Title -->
              <div style="flex: 1;">
                <strong>{item.title}</strong>
                <div class="admin-text-muted admin-text-sm">{item.url}</div>
              </div>
              
              <!-- Status -->
              <span class={`admin-table-status ${item.visible ? 'active' : 'hidden'}`}>
                <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span>
                {item.visible ? 'Görünür' : 'Gizli'}
              </span>
            </div>
            
            <!-- Actions -->
            <div class="admin-flex admin-gap-2">
              <button 
                class="admin-btn admin-btn-secondary admin-btn-icon admin-btn-sm" 
                title="Düzenle" 
                onclick={`openEditModal(${JSON.stringify(item)})`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </button>
              <button 
                class="admin-btn admin-btn-secondary admin-btn-icon admin-btn-sm" 
                title="Sil" 
                style="color: var(--admin-danger);"
                onclick={`confirmDelete(${item.id}, '${item.title}')`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</AdminLayout>

<style is:inline>
  .admin-alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: var(--admin-radius-md);
    font-size: 0.875rem;
  }
  
  .admin-alert-success {
    background: rgba(16, 185, 129, 0.15);
    color: var(--admin-success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }
  
  .admin-alert-warning {
    background: rgba(245, 158, 11, 0.15);
    color: var(--admin-warning);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }
  
  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(124, 58, 237, 0.2);
    color: var(--admin-accent-secondary);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .admin-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
  }
  
  .admin-modal-overlay.active {
    display: flex;
  }
  
  .admin-modal {
    background: var(--admin-bg-card);
    border: 1px solid var(--admin-border-color);
    border-radius: var(--admin-radius-lg);
    width: 100%;
    max-width: 500px;
  }
  
  .admin-modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--admin-border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .admin-modal-title {
    font-size: 1.125rem;
    font-weight: 600;
  }
  
  .admin-modal-close {
    background: none;
    border: none;
    color: var(--admin-text-muted);
    cursor: pointer;
    padding: 4px;
  }
  
  .admin-modal-body {
    padding: 24px;
  }
  
  .admin-modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--admin-border-color);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }
</style>

<!-- Edit/Add Modal -->
<div id="navModal" class="admin-modal-overlay">
  <div class="admin-modal">
    <div class="admin-modal-header">
      <h3 class="admin-modal-title" id="modalTitle">Menü Öğesi Düzenle</h3>
      <button class="admin-modal-close" onclick="closeModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <form method="POST" id="navForm">
      <input type="hidden" name="action" id="formAction" value="update">
      <input type="hidden" name="id" id="navId">
      
      <div class="admin-modal-body">
        <div class="admin-form-group">
          <label class="admin-form-label" for="navTitle">Menü Başlığı</label>
          <input type="text" id="navTitle" name="title" class="admin-form-input" placeholder="Menüde görünecek başlık" required>
        </div>
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="navUrl">URL</label>
          <input type="text" id="navUrl" name="url" class="admin-form-input" placeholder="/sayfa-adi" required>
        </div>
        
        <div class="admin-form-group">
          <label class="admin-form-label" for="navOrder">Sıra Numarası</label>
          <input type="number" id="navOrder" name="sort_order" class="admin-form-input" placeholder="1" min="1" required>
        </div>
        
        <div class="admin-form-group">
          <div class="admin-flex admin-items-center admin-justify-between">
            <label class="admin-form-label" style="margin-bottom: 0;">Menüde Görünsün</label>
            <label class="admin-toggle">
              <input type="checkbox" id="navVisible" name="visible" value="true" checked>
              <span class="admin-toggle-slider"></span>
            </label>
          </div>
          <input type="hidden" id="visibleHidden" name="visible" value="false">
        </div>
      </div>
      
      <div class="admin-modal-footer">
        <button type="button" class="admin-btn admin-btn-secondary" onclick="closeModal()">İptal</button>
        <button type="submit" class="admin-btn admin-btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Kaydet
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Form (Hidden) -->
<form id="deleteForm" method="POST" style="display: none;">
  <input type="hidden" name="action" value="delete">
  <input type="hidden" name="id" id="deleteId">
</form>

<script is:inline define:vars={{ navItems }}>
  function openEditModal(item) {
    document.getElementById('modalTitle').textContent = 'Menü Öğesi Düzenle';
    document.getElementById('formAction').value = 'update';
    document.getElementById('navId').value = item.id;
    document.getElementById('navTitle').value = item.title;
    document.getElementById('navUrl').value = item.url;
    document.getElementById('navOrder').value = item.sort_order;
    document.getElementById('navVisible').checked = item.visible;
    updateVisibleField();
    
    document.getElementById('navModal').classList.add('active');
  }
  
  function openAddModal() {
    const maxOrder = navItems.length > 0 ? Math.max(...navItems.map(n => n.sort_order)) + 1 : 1;
    
    document.getElementById('modalTitle').textContent = 'Yeni Menü Öğesi Ekle';
    document.getElementById('formAction').value = 'create';
    document.getElementById('navId').value = '';
    document.getElementById('navTitle').value = '';
    document.getElementById('navUrl').value = '/';
    document.getElementById('navOrder').value = maxOrder;
    document.getElementById('navVisible').checked = true;
    updateVisibleField();
    
    document.getElementById('navModal').classList.add('active');
  }
  
  function closeModal() {
    document.getElementById('navModal').classList.remove('active');
  }
  
  function updateVisibleField() {
    const checkbox = document.getElementById('navVisible');
    const hidden = document.getElementById('visibleHidden');
    hidden.disabled = checkbox.checked;
  }
  
  function confirmDelete(id, title) {
    if (confirm(`"${title}" menü öğesini silmek istediğinize emin misiniz?`)) {
      document.getElementById('deleteId').value = id;
      document.getElementById('deleteForm').submit();
    }
  }
  
  // Update visible field when checkbox changes
  document.getElementById('navVisible').addEventListener('change', updateVisibleField);
  
  // Close modal on outside click
  document.getElementById('navModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });
  
  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeModal();
    }
  });
</script>
