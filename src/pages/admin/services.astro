    <script is:inline>
        let originalExtraData = null;

        function openEditModal(section) {
            document.getElementById("sectionId").value = section.id;
            document.getElementById("sectionTitle").value = section.title || "";
            document.getElementById("sectionSubtitle").value =
                section.subtitle || "";
            document.getElementById("sectionDescription").value =
                section.description || "";
            document.getElementById("sectionImage").value =
                section.image_url || "";
            document.getElementById("buttonText").value =
                section.button_text || "";
            document.getElementById("buttonUrl").value =
                section.button_url || "";
            document.getElementById("sectionVisible").checked = section.visible;
            document.getElementById("modalSectionBadge").textContent =
                section.section_key;

            // Extra data
            originalExtraData = section.extra_data;
            const extraInput = document.getElementById("extraDataInput");
            if (
                section.extra_data &&
                Object.keys(section.extra_data).length > 0
            ) {
                extraInput.value = JSON.stringify(section.extra_data, null, 2);
                validateJson();
            } else {
                extraInput.value = "";
                updateJsonStatus("empty", "Veri yok");
            }

            // Extra tab badge
            const extraTabBtn = document.getElementById("extraTabBtn");
            if (
                section.extra_data &&
                Object.keys(section.extra_data).length > 0
            ) {
                extraTabBtn.textContent = "Ekstra Veriler ●";
            } else {
                extraTabBtn.textContent = "Ekstra Veriler";
            }

            updateVisibleField();
            switchTab("general");
            document.getElementById("editModal").classList.add("active");
        }

        function closeEditModal() {
            document.getElementById("editModal").classList.remove("active");
        }

        function switchTab(tabName) {
            document
                .querySelectorAll(".modal-tab")
                .forEach((t) => t.classList.remove("active"));
            document
                .querySelectorAll(".tab-panel")
                .forEach((p) => p.classList.remove("active"));

            const tabs = document.querySelectorAll(".modal-tab");
            if (tabName === "general") {
                tabs[0].classList.add("active");
            } else {
                tabs[1].classList.add("active");
            }
            document.getElementById("tab-" + tabName).classList.add("active");
        }

        function updateVisibleField() {
            const checkbox = document.getElementById("sectionVisible");
            const hidden = document.getElementById("visibleHidden");
            hidden.disabled = checkbox.checked;
        }

        function validateJson() {
            const input = document.getElementById("extraDataInput");
            const value = input.value.trim();

            if (!value) {
                input.classList.remove("json-invalid");
                updateJsonStatus("empty", "Veri yok");
                return true;
            }

            try {
                JSON.parse(value);
                input.classList.remove("json-invalid");
                updateJsonStatus("valid", "✓ Geçerli JSON");
                return true;
            } catch (e) {
                input.classList.add("json-invalid");
                updateJsonStatus(
                    "invalid",
                    "✗ Geçersiz: " + e.message.substring(0, 50),
                );
                return false;
            }
        }

        function updateJsonStatus(type, message) {
            const status = document.getElementById("jsonStatus");
            status.className = "json-status " + type;
            status.textContent = message;
        }

        function formatJson() {
            const input = document.getElementById("extraDataInput");
            try {
                const parsed = JSON.parse(input.value);
                input.value = JSON.stringify(parsed, null, 2);
                validateJson();
            } catch (e) {}
        }

        function compactJson() {
            const input = document.getElementById("extraDataInput");
            try {
                const parsed = JSON.parse(input.value);
                input.value = JSON.stringify(parsed);
                validateJson();
            } catch (e) {}
        }

        function resetJson() {
            const input = document.getElementById("extraDataInput");
            if (
                originalExtraData &&
                Object.keys(originalExtraData).length > 0
            ) {
                input.value = JSON.stringify(originalExtraData, null, 2);
            } else {
                input.value = "";
            }
            validateJson();
        }

        // Event listeners
        document
            .getElementById("sectionVisible")
            .addEventListener("change", updateVisibleField);

        document
            .getElementById("extraDataInput")
            .addEventListener("input", function () {
                validateJson();
            });

        // Tab key support for JSON editor
        document
            .getElementById("extraDataInput")
            .addEventListener("keydown", function (e) {
                if (e.key === "Tab") {
                    e.preventDefault();
                    const start = this.selectionStart;
                    const end = this.selectionEnd;
                    this.value =
                        this.value.substring(0, start) +
                        "  " +
                        this.value.substring(end);
                    this.selectionStart = this.selectionEnd = start + 2;
                }
            });

        // Form validation before submit
        document
            .getElementById("editForm")
            .addEventListener("submit", function (e) {
                const extraInput = document.getElementById("extraDataInput");
                const value = extraInput.value.trim();

                if (value && !validateJson()) {
                    e.preventDefault();
                    switchTab("extra");
                    alert(
                        "Ekstra veriler geçersiz JSON formatında. Lütfen düzeltin ve tekrar deneyin.",
                    );
                    return false;
                }
            });

        document
            .getElementById("editModal")
            .addEventListener("click", function (e) {
                if (e.target === this) {
                    closeEditModal();
                }
            });

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") {
                closeEditModal();
            }
        });
    </script>
</AdminLayout>
