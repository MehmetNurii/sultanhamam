    <script is:inline>
      (function() {
        console.log('🔧 Ajax Interceptor başlatılıyor...');
        
        // Interceptor fonksiyonu
        function installInterceptor(jq) {
          if (!jq || jq.ajax.__intercepted) return;
          
          console.log('🔧 jQuery bulundu, Ajax Interceptor kuruluyor...');
          var originalAjax = jq.ajax;
          
          jq.ajax = function(url, options) {
            if (typeof url === 'object') {
              options = url;
              url = options.url || '';
            }
            
            if (url && (url.includes('admin-ajax.php') || url.includes('wc-ajax'))) {
              console.log('🛑 Ajax isteği yakalandı:', url);
              
              // Mock yapilandirmasi - Absolute path kullan (server root'una göre)
              // Localhost'ta çalışırken /mirror/assets/... dizinine erişilebilmesi lazım
              // Eğer local server root'u 'mirror' klasörü ise yol 'assets/mock-ajax.json' olmalı
              // Ama garanti olsun diye relative path yerine absolute path veriyoruz ve
              // query string'i URL'den ayırıyoruz (dosya sisteminde query string olmaz)
              
              var mockPath = 'assets/mock-ajax.json'; 
              
              // Eğer sayfa alt klasördeyse (örn: light/home-two/), assets'e çıkmak için ../ gerekebilir
              // En garantisi, base tag'i kontrol etmek veya root-relative path kullanmak
              // Şimdilik 'assets/mock-ajax.json' kullanıyoruz, dosya yapısına göre bu değişebilir.
              
              if (options) {
                // Query string'i options.data içine veya url'in sonuna (cache busting için) ekleyebiliriz
                // Ama dosya isteği olduğu için query string dosya adını bozmamalı (browser tarayıcıda çalışırken)
                // Ancak local server (http-server vb) query string'i yoksayar ve dosyayı verir.
                // Dosya protokolü (file://) ise query string desteklemez.
                
                options.url = mockPath;
                options.type = 'GET';
                options.method = 'GET';
                
                // Cache busting için timestamp
                 options.data = Object.assign({}, options.data || {}, { t: new Date().getTime() });
              }
              
              // CRITICAL FIX: URL değişkenini de güncelle. 
              // ÖNEMLİ: Dosya sisteminde query string çalışmayabilir, o yüzden temiz path veriyoruz.
              url = mockPath;
              
              console.log('➡️ Yönlendirildi:', mockPath);
            }
            
            return originalAjax.call(this, url, options);
          };
          jq.ajax.__intercepted = true;
        }

        // 1. Zaten yüklüyse hemen kur
        if (window.jQuery) {
          installInterceptor(window.jQuery);
        }

        // 2. Gelecekte yüklenecekse yakala (Object.defineProperty ile)
        // Mevcut değeri sakla
        var _jq = window.jQuery;
        
        // Getter/Setter tanımla
        try {
          Object.defineProperty(window, 'jQuery', {
            get: function() { return _jq; },
            set: function(val) {
              _jq = val;
              if (val) {
                installInterceptor(val);
              }
            },
            configurable: true
          });
        } catch(e) {
          console.log('⚠️ Object.defineProperty başarısız (muhtemelen zaten tanımlı), setInterval fallback kullanılacak');
        }
        
        // 3. Güvenlik ağı: setInterval ile de kontrol et
        var checkInterval = setInterval(function() {
           if (window.jQuery) {
              installInterceptor(window.jQuery);
           }
        }, 50);
      })();
    </script>
    
    <style is:inline id="disable-scroll-animations">
      /* ===== ELEMENTOR SCROLL-BASED ANIMASYONLARINI DEVRE DIŞI BIRAK ===== */
      /* Bu CSS, scroll edince elementlerin tekrar tekrar animasyonlanmasını engeller */
      
      /* Invisible elementleri görünür yap */
      .elementor-invisible {
        visibility: visible !important;
        opacity: 1 !important;
      }
      
      /* Entrance animasyonlarını devre dışı bırak */
      [data-settings*="animation"],
      [data-settings*="_animation"],
      .animated,
      .elementor-widget[data-settings] {
        animation-duration: 0s !important;
        animation-delay: 0s !important;
      }
      
      /* fadeIn, zoomIn vb. animasyon class'ları için */
      .fadeIn, .fadeInUp, .fadeInDown, .fadeInLeft, .fadeInRight,
      .zoomIn, .zoomInUp, .zoomInDown, .zoomInLeft, .zoomInRight,
      .rotateIn, .rotateInDownLeft, .rotateInDownRight, .rotateInUpLeft, .rotateInUpRight,
      .slideInUp, .slideInDown, .slideInLeft, .slideInRight,
      .bounceIn, .bounceInUp, .bounceInDown, .bounceInLeft, .bounceInRight {
        animation-duration: 0s !important;
        animation-delay: 0s !important;
        opacity: 1 !important;
        visibility: visible !important;
      }
    </style>
    
    <script is:inline>
      // Sayfa yüklendiğinde tüm invisible elementleri visible yap
      document.addEventListener('DOMContentLoaded', function() {
        // Tüm .elementor-invisible elementlerini visible yap
        document.querySelectorAll('.elementor-invisible').forEach(function(el) {
          el.classList.remove('elementor-invisible');
          el.style.visibility = 'visible';
          el.style.opacity = '1';
        });
        
        // IntersectionObserver'ı override et (yeni animasyonları engelle)
        if (window.IntersectionObserver) {
          var OriginalIO = window.IntersectionObserver;
          window.IntersectionObserver = function(callback, options) {
            var wrappedCallback = function(entries, observer) {
              entries.forEach(function(entry) {
                // Tüm entry'leri intersecting olarak işaretle (animasyon tekrarını engelle)
                try {
                  Object.defineProperty(entry, 'isIntersecting', { value: true, writable: true });
                } catch(e) {}
              });
              callback(entries, observer);
            };
            return new OriginalIO(wrappedCallback, options);
          };
        }
      });
    </script>
