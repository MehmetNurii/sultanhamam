---
import { getPageSection } from "../lib/supabase";

const section = await getPageSection("contacts", "ask_question");

if (!section || !section.visible) {
	return null;
}

const title = (section.title as string | null) || "Ask a Question";
const description =
	(section.description as string | null) ||
	"If you have any questions, you can contact us. Please, fill out the form below.";
const imageUrl =
	(section.image_url as string | null) ||
	"/assets/light/wp-content/uploads/sites/4/2025/04/61-appointment.webp";
