---
import { getPageSection } from "../lib/supabase";

const section = await getPageSection("index", "pricing");

// Eğer section görünür değilse, hiçbir şey render etme
if (!section || !section.visible) {
	return null;
}

const title = section?.title || "Pricing plans for your wellness journey";
const description =
	section?.description ||
	"We offer simple, flat rate pricing for all our services. All initial consultations include treatment unless further testing is required.";
const buttonText = section?.button_text || "Full Price List";
const buttonUrl =
	section?.button_url ||
	"https://wellness-bliss.cmsmasters.studio/light/prices-page/";

const defaultPricingCategories = [
	{
		title: "Massage Therapy",
		description: "Stimulate the body's own healing response.",
		icon_class: "cmsms-demo-icons-wellness-bliss",
		detail_url: "/prices-page/",
		detail_text: "View Details",
		items: [
			{name: "Relaxation Massage - 60 mins", price: "$70"},
			{name: "Relaxation Massage - 90 mins", price: "$95"},
			{name: "Deep Tissue Massage - 60 mins", price: "$75"},
			{name: "Deep Tissue Massage - 90 mins", price: "$100"},
			{name: "Hot Stone Massage - 60 mins", price: "$80"},
			{name: "Hot Stone Massage - 90 mins", price: "$115"}
		]
	},
	{
		title: "Reflexology Therapy",
		description: "Relieve pain and limitation of movement.",
		icon_class: "cmsms-demo-icons-wellness-15",
		detail_url: "/prices-page/",
		detail_text: "View Details",
		groups: [
			{group_title: "Initial Consultation", items: [{name: "45 mins", price: "$50"}]},
			{group_title: "Follow Up Treatment", items: [{name: "30 mins", price: "$45"}, {name: "60 mins", price: "$60"}]}
		]
	},
	{
		title: "Acupuncture Session",
		description: "Stimulate the body's own healing response.",
		icon_class: "cmsms-demo-icons-wellness-11",
		detail_url: "/prices-page/",
		detail_text: "View Details",
		groups: [
			{group_title: "Initial Consultation", items: [{name: "45 mins", price: "$50"}]},
			{group_title: "Follow Up Treatment", items: [{name: "30 mins", price: "$45"}, {name: "60 mins", price: "$60"}]}
		]
	}
];

const pricingCategories = section?.extra_data?.pricing_categories || defaultPricingCategories;

// Orijinal elementor element ID'leri - CSS kurallarının doğru uygulanması için gerekli
const categoryElementIds = [
	{
		section: "51201cc",
		featuredBox: "ebc0ca2",
		listWidgets: ["1dab02a", "e32a3ed", "7394205"],
		repeaterItems: ["4ec200c", "9268d43"],
		button: "fb40b2b"
	},
	{
		section: "6fafec1",
		featuredBox: "575e14b",
		listWidgets: ["92cb895", "79a6d77"],
		repeaterItems: ["4ec200c", "10e1cd5"],
		button: "307b15b"
	},
	{
		section: "91c0ac3",
		featuredBox: "d4336ef",
		listWidgets: ["8eff959", "71a93e5"],
		repeaterItems: ["4ec200c", "10e1cd5"],
		button: "2b8033a"
	}
];

const bgSettings = [
	'{"background_background":"gradient","animation":"fadeIn"}',
	'{"background_background":"classic","animation":"fadeIn","animation_delay":250}',
	'{"background_background":"classic","animation":"fadeIn","animation_delay":500}'
];

// Helper: split flat items into pairs for display (Massage Therapy style)
function chunkArray(arr: any[], size: number) {
	const result: any[][] = [];
	for (let i = 0; i < arr.length; i += size) {
		result.push(arr.slice(i, i + size));
	}
	return result;
}
---

<section
	class="elementor-element elementor-element-ab3654b e-flex e-con-boxed cmsmasters-block-default e-con e-parent"
	data-id="ab3654b"
	data-element_type="container"
>
	<div class="e-con-inner">
		<div
			class="elementor-element elementor-element-505454a e-con-full e-flex cmsmasters-block-default e-con e-child"
			data-id="505454a"
			data-element_type="container"
		>
			<div
				class="elementor-element elementor-element-40d50dd elementor-widget__width-initial cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-heading"
				data-id="40d50dd"
				data-element_type="widget"
				data-settings='{"_animation":"fadeIn"}'
				data-widget_type="heading.default"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<h2 class="elementor-heading-title elementor-size-default">
						{title}
					</h2>
				</div>
			</div>
			<div
				data-animation-type="block"
				class="animation_type_block elementor-element elementor-element-5cf60d6 cmsmasters-featured-box__graphic-align-right cmsmasters-featured-box__link-button elementor-widget__width-initial cmsmasters-featured-box__graphic-align-mobile-left cmsmasters-featured-box__button-border-solid cmsmasters-featured-box__graphic-align-tablet-left cmsmasters-featured-box__text-valign-middle cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-featured-box animated fadeIn"
				data-animation-stagger=""
				data-separate-animation-selector=".elementor-widget-cmsmasters-featured-box__icon-wrap, .elementor-widget-cmsmasters-featured-box__image-wrap, .elementor-widget-cmsmasters-featured-box__title, .elementor-widget-cmsmasters-featured-box__description, .elementor-widget-cmsmasters-featured-box__button-wrapper"
				data-text-animation-class="sequental, random"
				data-id="5cf60d6"
				data-element_type="widget"
				data-settings='{"_animation":"fadeIn","_animation_delay":250}'
				data-widget_type="cmsmasters-featured-box.default"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<div
						class="elementor-widget-cmsmasters-featured-box__wrapper"
					>
						<div
							class="elementor-widget-cmsmasters-featured-box__content"
						>
							<div
								class="elementor-widget-cmsmasters-featured-box__content-vertical-inner"
							>
								<div
									class="elementor-widget-cmsmasters-featured-box__type-wrap elementor-widget-cmsmasters-featured-box__content-item"
								>
									<div
										class="elementor-widget-cmsmasters-featured-box__description elementor-widget-cmsmasters-featured-box__content-item"
									>
										{description}
									</div><div
										class="elementor-widget-cmsmasters-featured-box__button-wrapper elementor-widget-cmsmasters-featured-box__content-item"
									>
										<a
											class="elementor-widget-cmsmasters-featured-box__button elementor-widget-cmsmasters-featured-box__content-item cmsmasters-theme-button"
											href={buttonUrl}>{buttonText}</a
										>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div
			class="elementor-element elementor-element-b3c7823 e-grid e-con-full cmsmasters-block-default e-con e-child"
			data-id="b3c7823"
			data-element_type="container"
		>
			{pricingCategories.map((category, catIndex) => {
				const ids = categoryElementIds[catIndex] || categoryElementIds[0];
				return (
			<section
				class={`elementor-element elementor-element-${ids.section} e-con-full e-flex cmsmasters-block-default e-con e-child`}
				data-id={ids.section}
				data-element_type="container"
				data-settings={bgSettings[catIndex] || bgSettings[0]}
				style="visibility: visible; opacity: 1;"
			>
				<div
					data-separate-animation-selector=".elementor-widget-cmsmasters-featured-box__icon-wrap, .elementor-widget-cmsmasters-featured-box__image-wrap, .elementor-widget-cmsmasters-featured-box__title, .elementor-widget-cmsmasters-featured-box__description, .elementor-widget-cmsmasters-featured-box__button-wrapper"
					data-text-animation-class="sequental, random"
					class={`elementor-element elementor-element-${ids.featuredBox} cmsmasters-featured-box__graphic-align-left cmsmasters-featured-box__graphic-position-row-reverse cmsmasters-featured-box__graphic-position-tablet-row-reverse cmsmasters-featured-box__graphic-position-mobile-row-reverse cmsmasters-featured-box__graphic-position-tablet-v-top cmsmasters-featured-box__graphic-position-mobile-v-top cmsmasters-featured-box__graphic-position-v-top cmsmasters-featured-box__text-valign-middle cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-featured-box`}
					data-id={ids.featuredBox}
					data-element_type="widget"
					data-widget_type="cmsmasters-featured-box.default"
				>
					<div class="elementor-widget-container">
						<div
							class="elementor-widget-cmsmasters-featured-box__wrapper"
						>
							<div
								class="elementor-widget-cmsmasters-featured-box__content"
							>
								<div
									class="elementor-widget-cmsmasters-featured-box__content-vertical-inner"
								>
									<div
										class="elementor-widget-cmsmasters-featured-box__graphic-wrapper elementor-widget-cmsmasters-featured-box__content-item elementor-widget-cmsmasters-featured-box__icon"
									>
										<h3
											class="elementor-widget-cmsmasters-featured-box__title elementor-widget-cmsmasters-featured-box__content-item"
										>
											{category.title}
										</h3><div
											class="elementor-widget-cmsmasters-featured-box__icon-wrap elementor-widget-cmsmasters-featured-box__graphic-item"
										>
											<i
												aria-hidden="true"
												class={`cmsmsdemo-icons- ${category.icon_class}`}
											>
											</i>
										</div>
									</div><div
										class="elementor-widget-cmsmasters-featured-box__type-wrap elementor-widget-cmsmasters-featured-box__content-item"
									>
										<h3
											class="elementor-widget-cmsmasters-featured-box__title elementor-widget-cmsmasters-featured-box__content-item"
										>
											{category.title}
										</h3><div
											class="elementor-widget-cmsmasters-featured-box__description elementor-widget-cmsmasters-featured-box__content-item"
										>
											{category.description}
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				{/* Flat items rendering (e.g. Massage Therapy) */}
				{category.items && chunkArray(category.items, 2).map((pair, pairIdx) => (
				<div
					data-separate-animation-selector=".cmsmasters-widget-icon-list-item"
					data-text-animation-class="sequental, random, line, word, char"
					class={`elementor-element elementor-element-${ids.listWidgets[pairIdx] || ids.listWidgets[0]} cmsmasters-widget-layout-row cmsmasters-widget-align-stretch cmsmasters-widget-direction-default cmsmasters-widget-marker-element-icon cmsmasters-widget-marker-view-default cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-icon-list cmsmasters-widget-icon-list`}
					data-id={ids.listWidgets[pairIdx] || ids.listWidgets[0]}
					data-element_type="widget"
					data-widget_type="cmsmasters-icon-list.default"
				>
					<div class="elementor-widget-container">
						<ul class="cmsmasters-widget-icon-list-items">
							{pair.map((item, itemIdx) => (
							<li class="cmsmasters-widget-icon-list-item">
								<span
									class="cmsmasters-widget-icon-list-item-text-wrap"
								>
									<span
										class={`cmsmasters-widget-icon-list-item-text-inner elementor-repeater-item-${ids.repeaterItems[itemIdx] || ids.repeaterItems[0]}`}
									>
										<span
											class={`cmsmasters-widget-icon-list-item-text${itemIdx > 0 ? ' cmsmasters-widget-icon-list-item-text' : ''}`}
										>
											{item.name}
										</span>
									</span>
								</span>
								<span
									class="cmsmasters-widget-icon-list-item-value cmsmasters-widget-icon-list-item-value"
									>{item.price}</span
								>
							</li>
							))}
						</ul>
					</div>
				</div>
				))}

				{/* Grouped items rendering (e.g. Reflexology, Acupuncture) */}
				{category.groups && category.groups.map((group, groupIdx) => (
				<div
					data-separate-animation-selector=".cmsmasters-widget-icon-list-item"
					data-text-animation-class="sequental, random, line, word, char"
					class={`elementor-element elementor-element-${ids.listWidgets[groupIdx] || ids.listWidgets[0]} cmsmasters-widget-layout-row cmsmasters-widget-align-stretch cmsmasters-widget-direction-default cmsmasters-widget-marker-element-icon cmsmasters-widget-marker-view-default cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-icon-list cmsmasters-widget-icon-list`}
					data-id={ids.listWidgets[groupIdx] || ids.listWidgets[0]}
					data-element_type="widget"
					data-widget_type="cmsmasters-icon-list.default"
				>
					<div class="elementor-widget-container">
						<h4 class="cmsmasters-widget-icon-list-title">
							{group.group_title}
						</h4>
						<ul class="cmsmasters-widget-icon-list-items">
							{group.items.map((item, itemIdx) => (
							<li class="cmsmasters-widget-icon-list-item">
								<span
									class="cmsmasters-widget-icon-list-item-text-wrap"
								>
									<span
										class={`cmsmasters-widget-icon-list-item-text-inner elementor-repeater-item-${ids.repeaterItems[itemIdx] || ids.repeaterItems[0]}`}
									>
										<span
											class={`cmsmasters-widget-icon-list-item-text${itemIdx > 0 ? ' cmsmasters-widget-icon-list-item-text' : ''}`}
										>
											{item.name}
										</span>
									</span>
								</span>
								<span
									class="cmsmasters-widget-icon-list-item-value cmsmasters-widget-icon-list-item-value"
									>{item.price}</span
								>
							</li>
							))}
						</ul>
					</div>
				</div>
				))}

				<div
					class={`elementor-element elementor-element-${ids.button} cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-button`}
					data-id={ids.button}
					data-element_type="widget"
					data-settings='{"_animation":"fadeIn","_animation_delay":300}'
					data-widget_type="cmsmasters-button.default"
					style="visibility: visible; opacity: 1;"
				>
					<div class="elementor-widget-container">
						<div
							class="elementor-widget-cmsmasters-button__button-container"
						>
							<div
								class="elementor-widget-cmsmasters-button__button-container-inner"
							>
								<a
									href={category.detail_url}
									class="cmsmasters-button-link elementor-widget-cmsmasters-button__button cmsmasters-icon-view- cmsmasters-icon-shape- cmsmasters-button-size-sm"
									role="button"
									tabindex="0"
									><span
										class="elementor-widget-cmsmasters-button__content-wrapper cmsmasters-align-icon-"
										><span
											class="elementor-widget-cmsmasters-button__text"
											>{category.detail_text}</span
										></span
									></a
								>
							</div>
						</div>
					</div>
				</div>
			</section>
				);
			})}
		</div>
	</div>
</section>
