---
// Home Header Component - Transparent/Absolute positioned
// Used on: index page
import { getSiteSettings, type NavItem } from "../lib/supabase";

const settings = await getSiteSettings();
const email = settings.email || "example@wellness-bliss.com";
const phone = settings.phone || "+1 800-123-1234";
const phoneHref = phone.replace(/\s/g, "");
const address = settings.address || "Brooklyn, NY 10036, United States";
const logoUrl =
	settings.logo_url ||
	"/assets/light/wp-content/uploads/sites/4/2025/05/logo-2.svg";
const logoAlt = settings.logo_alt || "Light Demo";
const logoTitle = settings.logo_title || "Light Demo";
const siteUrl = settings.site_url || "/";
const bookVisitText = settings.book_visit_text || "Book a Visit";
const bookAppointmentText =
	settings.book_appointment_text || "Book an Appointment";
const bookAppointmentDesc =
	settings.book_appointment_description ||
	"Your life is waiting. Fast, long-lasting relief is nearby.";
const bookOnlineText = settings.book_online_text || "Book Online";

// Navigation from DB
let headerNav: NavItem[] = [];
try {
	const navJson = settings.header_navigation;
	if (navJson) headerNav = JSON.parse(navJson);
} catch (e) {
	console.error("Error parsing header_navigation:", e);
}

// SVG arrow icons
const chevronDown =
	'<svg aria-hidden="true" class="e-font-icon-svg e-fas-chevron-down" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z"></path></svg>';
const chevronRight =
	'<svg aria-hidden="true" class="e-font-icon-svg e-fas-chevron-right" viewBox="0 0 320 512" xmlns="http://www.w3.org/2000/svg"><path d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"></path></svg>';

// Filter visible items
const visibleHeaderNav = headerNav.filter((item) => item.visible !== false);

// === Render helpers for dynamic navigation ===
function renderMegaMenu(children: NavItem[]): string {
	const dataIds = [
		"35eed049",
		"1a04c110",
		"3888734c",
		"mega3",
		"mega4",
		"mega5",
	];
	let html =
		'<div class="elementor-widget-cmsmasters-nav-menu__megamenu-template-container cmsmasters-megamenu-container" style="width: 1280px; max-width: 1280px; transform: translateX(-368.531px);"><div class="elementor-widget-cmsmasters-nav-menu__megamenu-template-container-inner" style="max-width: 1280px;"><section data-elementor-type="section" data-elementor-id="116" class="elementor elementor-116 cmsmasters-location-cmsmasters_header cmsmasters-header-position-absolute-yes"><div class="elementor-inner"><div class="elementor-section-wrap"><section class="elementor-element elementor-element-3226d08f e-con-full e-grid cmsmasters-block-default e-con e-child" data-id="3226d08f" data-element_type="container" data-settings=\'{"background_background":"classic"}\'>';
	children.forEach((child: NavItem, idx: number) => {
		const did = dataIds[idx] || `mega${idx}`;
		const fp = idx === 0 ? ' fetchpriority="high"' : "";
		html += `<div data-separate-animation-selector=".elementor-widget-cmsmasters-featured-box__icon-wrap, .elementor-widget-cmsmasters-featured-box__image-wrap, .elementor-widget-cmsmasters-featured-box__title, .elementor-widget-cmsmasters-featured-box__description, .elementor-widget-cmsmasters-featured-box__button-wrapper" data-text-animation-class="sequental, random" class="elementor-element elementor-element-${did} cmsmasters-featured-box__link-box elementor-widget__width-inherit cmsmasters-featured-box__image_fit-cover e-transform cmsmasters-featured-box__graphic-align-center cmsmasters-featured-box__graphic-position-column cmsmasters-featured-box__graphic-position-tablet-column cmsmasters-featured-box__graphic-position-mobile-column cmsmasters-featured-box__text-valign-middle cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-featured-box" data-id="${did}" data-element_type="widget" data-settings='${JSON.stringify({ _transform_translateY_effect_hover: { unit: "px", size: -3, sizes: [] }, _transform_translateX_effect_hover: { unit: "px", size: "", sizes: [] }, _transform_translateX_effect_hover_widescreen: { unit: "px", size: "", sizes: [] }, _transform_translateX_effect_hover_tablet: { unit: "px", size: "", sizes: [] }, _transform_translateX_effect_hover_mobile: { unit: "px", size: "", sizes: [] }, _transform_translateY_effect_hover_widescreen: { unit: "px", size: "", sizes: [] }, _transform_translateY_effect_hover_tablet: { unit: "px", size: "", sizes: [] }, _transform_translateY_effect_hover_mobile: { unit: "px", size: "", sizes: [] } })}' data-widget_type="cmsmasters-featured-box.default"><div class="elementor-widget-container"><a href="${child.url}" class="elementor-widget-cmsmasters-featured-box__wrapper"><div class="elementor-widget-cmsmasters-featured-box__content"><div class="elementor-widget-cmsmasters-featured-box__content-vertical-inner"><div class="elementor-widget-cmsmasters-featured-box__graphic-wrapper elementor-widget-cmsmasters-featured-box__content-item elementor-widget-cmsmasters-featured-box__image"><h2 class="elementor-widget-cmsmasters-featured-box__title elementor-widget-cmsmasters-featured-box__content-item">${child.title}</h2><figure class="elementor-widget-cmsmasters-featured-box__image-wrap elementor-widget-cmsmasters-featured-box__graphic-item"><img${fp} width="360" height="255" src="${child.image_url || ""}" class="attachment-medium_large size-medium_large wp-image-46523" alt="" decoding="async" sizes="(max-width: 360px) 100vw, 360px"></figure></div><div class="elementor-widget-cmsmasters-featured-box__type-wrap elementor-widget-cmsmasters-featured-box__content-item"><h2 class="elementor-widget-cmsmasters-featured-box__title elementor-widget-cmsmasters-featured-box__content-item">${child.title}</h2></div></div></div></a></div></div>`;
	});
	html += "</section></div></div></section></div></div>";
	return html;
}

function renderDesktopSubmenu(items: NavItem[]): string {
	let html =
		'<ul class="sub-menu elementor-widget-cmsmasters-nav-menu__dropdown-submenu">';
	items.forEach((item: NavItem) => {
		if (item.visible === false) return;
		const hasChildren = item.children && item.children.length > 0;
		const cls = `menu-item menu-item-type-custom menu-item-object-custom${hasChildren ? " menu-item-has-children" : ""}`;
		const linkHref =
			item.url && item.url !== "#" ? ` href="${item.url}"` : "";
		html += `<li class="${cls}"><a${linkHref} class="elementor-widget-cmsmasters-nav-menu__dropdown-item sub elementor-widget-cmsmasters-nav-menu__item-link-sub" aria-label="Menu item"><span class="elementor-widget-cmsmasters-nav-menu__item-text-wrap"><span class="elementor-widget-cmsmasters-nav-menu__item-text">${item.title}</span><span class="elementor-widget-cmsmasters-nav-menu__arrow" role="button" title="Menu item arrow" tabindex="0"><span class="cmsmasters-wrap-icon">${chevronRight}</span></span></span><span class="cmsmasters-animation"></span></a>`;
		if (hasChildren) html += renderDesktopSubmenu(item.children!);
		html += "</li>";
	});
	html += "</ul>";
	return html;
}

function renderDesktopNavItem(item: NavItem, idx: number): string {
	if (item.visible === false) return "";
	const hasChildren = item.children && item.children.length > 0;
	const cls = `menu-item menu-item-type-custom menu-item-object-custom${hasChildren ? " menu-item-has-children" : ""}${item.menu_type === "mega_menu" ? " cmsmasters-megamenu-type-template" : ""}`;
	const linkHref = item.url && item.url !== "#" ? ` href="${item.url}"` : "";
	let html = `<li class="${cls}"><a${linkHref} class="elementor-widget-cmsmasters-nav-menu__dropdown-item elementor-widget-cmsmasters-nav-menu__item-link-top" aria-label="Menu item"><span class="elementor-widget-cmsmasters-nav-menu__item-text-wrap"><span class="elementor-widget-cmsmasters-nav-menu__item-text">${item.title}</span><span class="elementor-widget-cmsmasters-nav-menu__arrow" role="button" title="Menu item arrow" tabindex="0"><span class="cmsmasters-wrap-icon">${chevronDown}</span></span></span><span class="cmsmasters-animation"></span></a>`;
	if (hasChildren) {
		if (item.menu_type === "mega_menu") {
			html += renderMegaMenu(item.children!);
		} else {
			html += renderDesktopSubmenu(item.children!);
		}
	}
	html += "</li>";
	return html;
}

function renderVerticalNavItem(item: NavItem, isTop: boolean): string {
	if (item.visible === false) return "";
	const hasChildren = item.children && item.children.length > 0;
	const cls = `menu-item menu-item-type-custom menu-item-object-custom${hasChildren ? " menu-item-has-children" : ""}`;
	const linkHref = item.url && item.url !== "#" ? ` href="${item.url}"` : "";
	const linkClass = isTop
		? "elementor-widget-cmsmasters-nav-menu__dropdown-item elementor-widget-cmsmasters-nav-menu__item-link-top"
		: "elementor-widget-cmsmasters-nav-menu__dropdown-item sub elementor-widget-cmsmasters-nav-menu__item-link-sub";
	let html = `<li class="${cls}"><a${linkHref} class="${linkClass}" aria-label="Menu item"><span class="elementor-widget-cmsmasters-nav-menu__item-text-wrap"><span class="elementor-widget-cmsmasters-nav-menu__item-text">${item.title}</span><span class="elementor-widget-cmsmasters-nav-menu__arrow" role="button" title="Menu item arrow" tabindex="0"><span class="cmsmasters-wrap-icon">${chevronDown}</span></span></span></a>`;
	if (hasChildren) {
		html +=
			'<ul class="sub-menu elementor-widget-cmsmasters-nav-menu__dropdown-submenu">';
		item.children!.forEach((child: NavItem) => {
			html += renderVerticalNavItem(child, false);
		});
		html += "</ul>";
	}
	html += "</li>";
	return html;
}

function renderDropdownNavItem(item: NavItem, isTop: boolean): string {
	if (item.visible === false) return "";
	const hasChildren = item.children && item.children.length > 0;
	const cls = `menu-item menu-item-type-custom menu-item-object-custom${hasChildren ? " menu-item-has-children" : ""}`;
	const linkHref = item.url && item.url !== "#" ? ` href="${item.url}"` : "";
	const linkClass = isTop
		? "elementor-widget-cmsmasters-nav-menu__dropdown-item"
		: "elementor-widget-cmsmasters-nav-menu__dropdown-item sub";
	let html = `<li class="${cls}"><a${linkHref} class="${linkClass}" aria-label="Menu item"><span class="elementor-widget-cmsmasters-nav-menu__item-text-wrap"><span class="elementor-widget-cmsmasters-nav-menu__item-text">${item.title}</span><span class="elementor-widget-cmsmasters-nav-menu__arrow" role="button" title="Menu item arrow" tabindex="0"><span class="cmsmasters-wrap-icon">${chevronDown}</span></span></span></a>`;
	if (hasChildren) {
		html +=
			'<ul class="sub-menu elementor-widget-cmsmasters-nav-menu__dropdown-submenu">';
		item.children!.forEach((child: NavItem) => {
			html += renderDropdownNavItem(child, false);
		});
		html += "</ul>";
	}
	html += "</li>";
	return html;
}

// Pre-render navigation HTML
const desktopNavHtml = visibleHeaderNav
	.map((item: NavItem, idx: number) => renderDesktopNavItem(item, idx))
	.join("");
const mobilePopupNavHtml = visibleHeaderNav
	.map((item: NavItem) => renderVerticalNavItem(item, true))
	.join("");
const mobileDropdownNavHtml = visibleHeaderNav
	.map((item: NavItem) => renderDropdownNavItem(item, true))
	.join("");
