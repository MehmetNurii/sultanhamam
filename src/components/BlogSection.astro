---
import { getPageSection } from "../lib/supabase";

const section = await getPageSection("index", "blog");

// Eğer section görünür değilse, hiçbir şey render etme
if (!section || !section.visible) {
	return null;
}

const title = section?.title || "Wellness Blog";
const buttonText = section?.button_text || "More Blog Posts";
const buttonUrl =
	section?.button_url ||
	"https://wellness-bliss.cmsmasters.studio/light/blog-page/";

const defaultBlogPosts = [
	{image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-blog-1-1024x581.webp", category: "Wellness", date: "April 13, 2025", title: "5 Ways Regular Massage Therapy Can Improve Your Overall Wellbeing", post_url: "https://wellness-bliss.cmsmasters.studio/light/5-ways-regular-massage-therapy-can-improve-your-overall-wellbeing/"},
	{image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-blog-9-300x170.webp", category: "Wellness", date: "April 2, 2025", title: "The Best Way to Relax: Himalayan Hot Stone Massage", post_url: "https://wellness-bliss.cmsmasters.studio/light/the-best-way-to-relax-himalayan-hot-stone-massage/"},
	{image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-blog-8-300x170.webp", category: "Wellness", date: "April 4, 2025", title: "Your Skin's Health & Vitality are Just a Facial Away!", post_url: "https://wellness-bliss.cmsmasters.studio/light/your-skins-health-vitality-are-just-a-facial-away/"},
	{image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-blog-7-300x170.webp", category: "Wellness", date: "April 5, 2025", title: "What to Expect from Our Upcoming Shirdhara Ayurvedic Treatment", post_url: "https://wellness-bliss.cmsmasters.studio/light/what-to-expect-from-our-upcoming-shirdhara-ayurvedic-treatment/"},
	{image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-blog-6-300x170.webp", category: "Wellness", date: "April 7, 2025", title: "Discover Natural Pain Relief with Massage Therapy", post_url: "https://wellness-bliss.cmsmasters.studio/light/discover-natural-pain-relief-with-massage-therapy/"}
];
const rawBlogPosts = section?.extra_data?.blog_posts || defaultBlogPosts;
// Alan ismi uyumluluğu: SQL'de "image"/"url" olabilir, bileşen "image_url"/"post_url" bekliyor
const blogPosts = rawBlogPosts.map((post: any) => ({
	...post,
	image_url: post.image_url || post.image,
	post_url: post.post_url || post.url,
}));

// First post is featured (big), rest are small
const featuredPost = blogPosts[0];
const smallPosts = blogPosts.slice(1);
