---
import { getPageSection } from "../lib/supabase";

const section = await getPageSection("index", "about");

// Eğer section görünür değilse, hiçbir şey render etme
if (!section || !section.visible) {
	return null;
}

const description =
    section?.description ||
    "At Wellness Bliss, we believe true healing begins with presence and touch. Each session is a one-on-one experience with a skilled therapist who takes the time to understand your body's needs, helping you achieve real, lasting results.";
const imageUrl =
    section?.image_url ||
    "/assets/light/wp-content/uploads/sites/4/2025/04/61-home-2-3.webp";
const buttonText = section?.button_text || "More About Us";
const buttonUrl =
    section?.button_url ||
    "https://wellness-bliss.cmsmasters.studio/light/about-us/";
---

<section
    class="elementor-element elementor-element-ab6b4a1 e-con-full e-flex cmsmasters-block-default e-con e-parent e-lazyloaded"
    data-id="ab6b4a1"
    data-element_type="container"
>
    <div
        class="elementor-element elementor-element-d68f180 e-con-full e-flex cmsmasters-bg-hide-none cmsmasters-bg-hide-none cmsmasters-block-default e-con e-child"
        data-id="d68f180"
        data-element_type="container"
        data-settings='{"background_background":"classic"}'
    >
    </div>
    <div
        class="elementor-element elementor-element-858013f e-con-full e-flex cmsmasters-bg-hide-none cmsmasters-bg-hide-none cmsmasters-block-default e-con e-child"
        data-id="858013f"
        data-element_type="container"
        data-settings='{"background_background":"classic"}'
    >
        <div
            class="elementor-element elementor-element-122e028 elementor-widget__width-initial elementor-absolute cmsmasters-effect cmsmasters-effect-type-scroll elementor-hidden-tablet elementor-hidden-mobile cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-image"
            data-id="122e028"
            data-element_type="widget"
            data-settings='{"_position":"absolute","cms_scroll_effects":["vertical"],"cms_scroll_vertical_speed":{"unit":"px","size":2,"sizes":[]},"cms_scroll_vertical":"yes","cms_scroll_vertical_direction":"default","cms_scroll_vertical_timing":"linear","cms_scroll_viewport":{"unit":"%","size":"","sizes":{"start":0,"end":100}},"cms_scroll_range":"viewport","cms_scroll_devices":["desktop","tablet","mobile"]}'
            data-widget_type="image.default"
            data-scroll-desktop=""
            data-scroll-tablet=""
            data-scroll-mobile=""
            style="--cmsmasters-scroll-vertical: -100px;"
        >
            <div class="elementor-widget-container">
                <img
                    loading="lazy"
                    decoding="async"
                    width="250"
                    height="290"
                    src={imageUrl}
                    class="attachment-medium size-medium wp-image-44309"
                    alt=""
                />
            </div>
        </div>
        <div
            class="elementor-element elementor-element-06213c1 cmsmasters-effect cmsmasters-effect-type-scroll elementor-view-default cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-icon"
            data-id="06213c1"
            data-element_type="widget"
            data-settings='{"_animation":"rotateIn","cms_scroll_effects":["rotate"],"cms_scroll_rotate_direction":"reverse","cms_scroll_rotate":"yes","cms_scroll_rotate_speed":{"unit":"px","size":6,"sizes":[]},"cms_scroll_rotate_timing":"linear","cms_scroll_origin_y":"center","cms_scroll_origin_x":"center","cms_scroll_viewport":{"unit":"%","size":"","sizes":{"start":0,"end":100}},"cms_scroll_range":"viewport","cms_scroll_devices":["desktop","tablet","mobile"]}'
            data-widget_type="icon.default"
            data-scroll-desktop=""
            data-scroll-tablet=""
            data-scroll-mobile=""
            style="--cmsmasters-scroll-rotate: 540deg; --cmsmasters-scroll-origin-x: center; --cmsmasters-scroll-origin-y: center; visibility: visible; opacity: 1;"
        >
            <div class="elementor-widget-container">
                <div class="elementor-icon-wrapper">
                    <div class="elementor-icon">
                        <i
                            aria-hidden="true"
                            class="cmsmsdemo-icons- cmsms-demo-icons-wellness-bliss"
                        ></i>
                    </div>
                </div>
            </div>
        </div>
        <div
            class="elementor-element elementor-element-8dc0fd4 elementor-widget__width-initial cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-heading"
            data-id="8dc0fd4"
            data-element_type="widget"
            data-settings='{"_animation":"fadeIn","_animation_delay":250}'
            data-widget_type="heading.default"
            style="visibility: visible; opacity: 1;"
        >
            <div class="elementor-widget-container">
                <p class="elementor-heading-title elementor-size-default">
                    {description}
                </p>
            </div>
        </div>
        <div
            class="elementor-element elementor-element-48d3d8d cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-button"
            data-id="48d3d8d"
            data-element_type="widget"
            data-settings='{"_animation":"fadeInUp","_animation_delay":500}'
            data-widget_type="cmsmasters-button.default"
            style="visibility: visible; opacity: 1;"
        >
            <div class="elementor-widget-container">
                <div
                    class="elementor-widget-cmsmasters-button__button-container"
                >
                    <div
                        class="elementor-widget-cmsmasters-button__button-container-inner"
                    >
                        <a
                            href={buttonUrl}
                            class="cmsmasters-button-link elementor-widget-cmsmasters-button__button cmsmasters-icon-view- cmsmasters-icon-shape- cmsmasters-button-size-sm"
                            role="button"
                            tabindex="0"
                            ><span
                                class="elementor-widget-cmsmasters-button__content-wrapper cmsmasters-align-icon-"
                                ><span
                                    class="elementor-widget-cmsmasters-button__text"
                                    >{buttonText}</span
                                ></span
                            ></a
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
