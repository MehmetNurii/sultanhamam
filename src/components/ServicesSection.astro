															</div>
															<div
																class="elementor-element elementor-element-2399a569 e-con-full cmsmasters-effect cmsmasters-effect-type-transform cmsmasters-effect-hover-type-section e-flex cmsmasters-block-default e-con e-child"
																data-id="2399a569"
																data-element_type="container"
																data-settings={overlaySettings}
															>
															</div>
														</div>
													</div>
												</div>
											</div>
										</div>
									</article>
										);
