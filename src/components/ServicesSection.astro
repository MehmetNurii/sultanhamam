---
import { getPageSection } from "../lib/supabase";

const section = await getPageSection("index", "services");

// Eğer section görünür değilse, hiçbir şey render etme
if (!section || !section.visible) {
	return null;
}

const title = section?.title || "Our Services";
const subtitle = section?.subtitle || null;
const description = section?.description || null;
const buttonText = section?.button_text || "View all Services";
const buttonUrl =
	section?.button_url || "/services-page";

const defaultServices = [
	{ title: "Swedish Relaxation Massage", description: "Using gentle to medium pressure and flowing strokes, this massage promotes deep relaxation, improves circulation, and soothes tired muscles.", icon_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-icon-7.svg", bg_image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-7.webp", button_text: "Read More", url: "/services/swedish-relaxation-massage/" },
	{ title: "Facial Massage", description: "Our facial massage uses light, soothing strokes to boost circulation, release tension, and enhance your skin\u2019s natural glow.", icon_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-icon-8.svg", bg_image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-8.webp", button_text: "Read More", url: "/services/facial-massage/" },
	{ title: "Aromatherapy Massage", description: "This massage combines gentle, flowing techniques with the healing power of essential oils chosen specifically for your needs \u2014 whether calming, energizing, or balancing.", icon_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-icon-9.svg", bg_image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-9.webp", button_text: "Read More", url: "/services/aromatherapy-massage/" },
	{ title: "Hot Stone Massage", description: "Smooth, heated stones are placed on key points of the body and used in flowing massage strokes to ease muscle tension and enhance circulation.", icon_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-icon-10.svg", bg_image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-10.webp", button_text: "Read More", url: "/services/hot-stone-massage/" },
	{ title: "Deep Tissue Therapy", description: "This intensive massage technique targets deeper layers of muscle and connective tissue to relieve chronic pain, stiffness, and tension.", icon_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-icon-11.svg", bg_image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-11.webp", button_text: "Read More", url: "/services/deep-tissue-therapy/" },
	{ title: "Reflexology Therapy", description: "This specialized treatment focuses on pressure points in the feet, hands, and ears that correspond to different organs and systems of the body.", icon_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-icon-12.svg", bg_image_url: "/assets/light/wp-content/uploads/sites/4/2025/04/61-service-12.webp", button_text: "Read More", url: "/services/reflexology-therapy/" },
];
const services = section?.extra_data?.services || defaultServices;

const transformHoverSettings = JSON.stringify({"cms_transform_hover_type":"section","cms_transform_out_row_id_hover":".cmsms_container_for_transform_hover_effect","cms_transform_out_row_custom_selector_hover":[":hover .elementor-element.elementor-element-{{ID}}",":hover .e-con.cmsmasters-effect-type-transform.elementor-element.elementor-element-{{ID}}",":hover .elementor-column.cmsmasters-effect-type-transform > .elementor-widget-wrap"],"cms_transform_out_row_custom_value_hover":"transform: translate(var(--cmsmasters-transform-translate-x-hover, var(--cmsmasters-transform-translate-x)), var(--cmsmasters-transform-translate-y-hover, var(--cmsmasters-transform-translate-y))) rotateZ(var(--cmsmasters-transform-rotate-z-hover, var(--cmsmasters-transform-rotate-z))) rotateX(var(--cmsmasters-transform-rotate-x-hover, var(--cmsmasters-transform-rotate-x))) rotateY(var(--cmsmasters-transform-rotate-y-hover, var(--cmsmasters-transform-rotate-y))) scale(var(--cmsmasters-transform-scale-x-hover, var(--cmsmasters-transform-scale-x)), var(--cmsmasters-transform-scale-y-hover, var(--cmsmasters-transform-scale-y))) skew(var(--cmsmasters-transform-skew-x-hover, var(--cmsmasters-transform-skew-x)), var(--cmsmasters-transform-skew-y-hover, var(--cmsmasters-transform-skew-y))); opacity: var(--cmsmasters-transform-opacity-hover, var(--cmsmasters-transform-opacity)); backdrop-filter: blur(var(--cmsmasters-transform-blur-hover, var(--cmsmasters-transform-blur)));"});

const overlaySettings = JSON.stringify({"background_background":"classic","position":"absolute","cms_transform_hover_type":"section","cms_transform_out_row_id_hover":".cmsms_container_for_transform_hover_effect","cms_transform_out_row_custom_selector_hover":[":hover .elementor-element.elementor-element-{{ID}}",":hover .e-con.cmsmasters-effect-type-transform.elementor-element.elementor-element-{{ID}}",":hover .elementor-column.cmsmasters-effect-type-transform > .elementor-widget-wrap"],"cms_transform_out_row_custom_value_hover":"transform: translate(var(--cmsmasters-transform-translate-x-hover, var(--cmsmasters-transform-translate-x)), var(--cmsmasters-transform-translate-y-hover, var(--cmsmasters-transform-translate-y))) rotateZ(var(--cmsmasters-transform-rotate-z-hover, var(--cmsmasters-transform-rotate-z))) rotateX(var(--cmsmasters-transform-rotate-x-hover, var(--cmsmasters-transform-rotate-x))) rotateY(var(--cmsmasters-transform-rotate-y-hover, var(--cmsmasters-transform-rotate-y))) scale(var(--cmsmasters-transform-scale-x-hover, var(--cmsmasters-transform-scale-x)), var(--cmsmasters-transform-scale-y-hover, var(--cmsmasters-transform-scale-y))) skew(var(--cmsmasters-transform-skew-x-hover, var(--cmsmasters-transform-skew-x)), var(--cmsmasters-transform-skew-y-hover, var(--cmsmasters-transform-skew-y))); opacity: var(--cmsmasters-transform-opacity-hover, var(--cmsmasters-transform-opacity)); backdrop-filter: blur(var(--cmsmasters-transform-blur-hover, var(--cmsmasters-transform-blur)));"});

const titleAbsoluteSettings = JSON.stringify({"_position":"absolute","cms_transform_hover_type":"section","cms_transform_out_row_id_hover":".cmsms_container_for_transform_hover_effect","cms_transform_out_row_custom_selector_hover":[":hover .elementor-element.elementor-element-{{ID}}",":hover .e-con.cmsmasters-effect-type-transform.elementor-element.elementor-element-{{ID}}",":hover .elementor-column.cmsmasters-effect-type-transform > .elementor-widget-wrap"],"cms_transform_out_row_custom_value_hover":"transform: translate(var(--cmsmasters-transform-translate-x-hover, var(--cmsmasters-transform-translate-x)), var(--cmsmasters-transform-translate-y-hover, var(--cmsmasters-transform-translate-y))) rotateZ(var(--cmsmasters-transform-rotate-z-hover, var(--cmsmasters-transform-rotate-z))) rotateX(var(--cmsmasters-transform-rotate-x-hover, var(--cmsmasters-transform-rotate-x))) rotateY(var(--cmsmasters-transform-rotate-y-hover, var(--cmsmasters-transform-rotate-y))) scale(var(--cmsmasters-transform-scale-x-hover, var(--cmsmasters-transform-scale-x)), var(--cmsmasters-transform-scale-y-hover, var(--cmsmasters-transform-scale-y))) skew(var(--cmsmasters-transform-skew-x-hover, var(--cmsmasters-transform-skew-x)), var(--cmsmasters-transform-skew-y-hover, var(--cmsmasters-transform-skew-y))); opacity: var(--cmsmasters-transform-opacity-hover, var(--cmsmasters-transform-opacity)); backdrop-filter: blur(var(--cmsmasters-transform-blur-hover, var(--cmsmasters-transform-blur)));"});
---

<section
	class="elementor-element elementor-element-4dd5f9b e-flex e-con-boxed cmsmasters-block-default e-con e-parent e-lazyloaded"
	data-id="4dd5f9b"
	data-element_type="container"
>
	<div class="e-con-inner">
		<div
			class="elementor-element elementor-element-004d4a0 e-con-full e-flex cmsmasters-block-default e-con e-child"
			data-id="004d4a0"
			data-element_type="container"
		>
			<div
				class="elementor-element elementor-element-41a1441 cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-heading animated fadeIn"
				data-id="41a1441"
				data-element_type="widget"
				data-settings='{"_animation":"fadeIn"}'
				data-widget_type="heading.default"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<h2 class="elementor-heading-title elementor-size-default">
						{title}
					</h2>
				</div>
			</div>
			<div
				class="elementor-element elementor-element-83c52be cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-button animated fadeInUp"
				data-id="83c52be"
				data-element_type="widget"
				data-settings='{"_animation":"fadeInUp","_animation_delay":250}'
				data-widget_type="cmsmasters-button.default"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<div
						class="elementor-widget-cmsmasters-button__button-container"
					>
						<div
							class="elementor-widget-cmsmasters-button__button-container-inner"
						>
							<a
								href={buttonUrl}
								class="cmsmasters-button-link elementor-widget-cmsmasters-button__button cmsmasters-icon-view- cmsmasters-icon-shape- cmsmasters-button-size-sm"
								role="button"
								tabindex="0"
								><span
									class="elementor-widget-cmsmasters-button__content-wrapper cmsmasters-align-icon-"
									><span
										class="elementor-widget-cmsmasters-button__text"
										>{buttonText}</span
									></span
								></a
							>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div
			class="elementor-element elementor-element-2f95b0d e-con-full e-flex cmsmasters-block-default e-con e-child"
			data-id="2f95b0d"
			data-element_type="container"
		>
			<div
				class="elementor-element elementor-element-8d320fc cmsmasters-blog--layout-custom elementor-widget-tablet__width-inherit cmsmasters-blog-grid-marker__marker-icon cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-blog-grid elementor-widget-cmsmasters-blog-similar animated fadeIn"
				data-id="8d320fc"
				data-element_type="widget"
				data-settings='{"blog_layout":"custom","blog_template_id":"136","post_gap_column":{"unit":"px","size":30,"sizes":[]},"post_gap_row":{"unit":"px","size":30,"sizes":[]},"columns_tablet":"2","blog_post_type":"services","_animation":"fadeIn","_animation_delay":500,"columns":3,"columns_mobile":"1","query_control_prefix":"blog","post_gap_column_widescreen":{"unit":"px","size":"","sizes":[]},"post_gap_column_tablet":{"unit":"px","size":"","sizes":[]},"post_gap_row_widescreen":{"unit":"px","size":"","sizes":[]},"post_gap_row_tablet":{"unit":"px","size":"","sizes":[]},"post_gap_row_mobile":{"unit":"px","size":"","sizes":[]}}'
				data-widget_type="cmsmasters-blog-grid.default"
				data-document-id="37907"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<div
						class="cmsmasters-blog cmsmasters-blog-grid cmsmasters-blog--type-default"
					>
						<div class="cmsmasters-blog__posts-variable">
							<div class="cmsmasters-blog__posts-wrap">
								<div class="cmsmasters-blog__posts">
									{services.map((service: any, index: number) => {
										const cardId = `service-card-${index}`;
										return (
									<article
										id={cardId}
										class={`cmsmasters-blog__post ${cardId} type-services status-publish has-post-thumbnail hentry service_category-sensory-relaxation-therapies`}
									>
										<div
											class="cmsmasters-blog__post-inner"
										>
											<style is:inline set:html={`
												.${cardId}
													.elementor-element.elementor-element-703df6:not(
														.elementor-motion-effects-element-type-background
													):not(
														.cmsmasters-bg-effect
													),
												.${cardId}
													.elementor-element.elementor-element-703df6
													> .elementor-motion-effects-container
													> .elementor-motion-effects-layer,
												.${cardId}
													.elementor-element.elementor-element-703df6
													> .cmsmasters-bg-effects-container
													> .cmsmasters-bg-effects-element {
													background-image: url("${service.bg_image_url}");
												}
											`} />
											<div
												data-elementor-type="cmsmasters_entry"
												data-elementor-id="136"
												class="elementor elementor-136"
												data-elementor-title="Entry"
											>
												<div class="elementor-inner">
													<div
														class="elementor-section-wrap"
													>
														<div
															class="elementor-element elementor-element-703df6 e-con-full cmsms_container_for_transform_hover_effect e-flex cmsmasters-bg-hide-none cmsmasters-bg-hide-none cmsmasters-block-default e-con e-parent"
															data-id="703df6"
															data-element_type="container"
															data-settings='{"background_background":"classic"}'
														>
															<div
																class="elementor-element elementor-element-24f394e9 elementor-widget__width-inherit cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-image"
																data-id="24f394e9"
																data-element_type="widget"
																data-widget_type="image.default"
															>
																<div
																	class="elementor-widget-container"
																>
																	<img
																		src={service.icon_url}
																		title=""
																		alt=""
																		loading="lazy"
																	/>
																</div>
															</div>
															<div
																class="elementor-element elementor-element-2ff79b07 e-con-full cmsmasters-effect-hover-type-section cmsmasters-effect cmsmasters-effect-type-transform e-flex cmsmasters-block-default e-con e-child"
