import { getPageSection } from "../lib/supabase";

const section = await getPageSection("prices-page", "pricing_categories");

// Eğer section görünür değilse, hiçbir şey render etme
if (!section || !section.visible) {
	return null;
}

interface PricingItem { name: string; price: string; }
interface PricingGroup { group_title: string; items: PricingItem[]; }
interface PricingCategory {
	title: string;
	description: string;
	icon_class?: string;
	detail_url?: string;
	detail_text?: string;
	items?: PricingItem[];
	groups?: PricingGroup[];
}
const pricingCategories = (section?.extra_data?.pricing_categories as PricingCategory[] | undefined) || [];

// Her zaman 6 slot: eksik kategoride statik fallback (grid yapısı bozulmasın)
const defaultCat = (i: number): PricingCategory => ({
	title: ["Massage Therapy", "Guided Meditations", "Reflexology Therapy", "Lymphatic Drainage Massage", "Aromatherapy Session", "Intuitive Wellness Consultation"][i] ?? "",
	description: ["{getCat(0).description}", "Breathwork and mindfulness tailored to your needs.", "Relieve pain and limitation of movement.", "Gentle technique to support immune function and reduce inflammation.", "Deeply relax the body, mind and soul.", "Holistic life guidance blending energy reading, herbal suggestions."][i] ?? "",
	icon_class: ["cmsms-demo-icons-wellness-bliss", "cmsms-demo-icons-wellness-12", "cmsms-demo-icons-wellness-15", "cmsms-demo-icons-wellness-8", "cmsms-demo-icons-wellness-11", "cmsms-demo-icons-wellness-9"][i] ?? "",
	detail_url: "#",
	detail_text: "View Details",
	items: [],
	groups: [{ group_title: "Initial Consultation", items: [{ name: "45 mins", price: "$50" }] }, { group_title: "Follow Up Treatment", items: [{ name: "30 mins", price: "$40" }, { name: "60 mins", price: "$60" }] }]
});
function getCat(i: number): PricingCategory { return pricingCategories[i] ?? defaultCat(i); }
function chunk<T>(arr: T[], n: number): T[][] { const r: T[][] = []; for (let i = 0; i < arr.length; i += n) r.push(arr.slice(i, i + n)); return r; }

// Her kategori için element ID'leri (PriceListSection'ın orijinal yapısı için)
