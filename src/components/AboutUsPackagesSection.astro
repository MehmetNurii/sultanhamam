const overlaySettings = `{"background_background":"classic","position":"absolute","cms_transform_hover_type":"section","cms_transform_out_row_id_hover":".cmsms_container_for_transform_hover_effect","cms_transform_out_row_custom_selector_hover":[":hover .elementor-element.elementor-element-{{ID}}",":hover .e-con.cmsmasters-effect-type-transform.elementor-element.elementor-element-{{ID}}",":hover .elementor-column.cmsmasters-effect-type-transform > .elementor-widget-wrap"],"cms_transform_out_row_custom_value_hover":"transform: translate(var(--cmsmasters-transform-translate-x-hover, var(--cmsmasters-transform-translate-x)), var(--cmsmasters-transform-translate-y-hover, var(--cmsmasters-transform-translate-y))) rotateZ(var(--cmsmasters-transform-rotate-z-hover, var(--cmsmasters-transform-rotate-z))) rotateX(var(--cmsmasters-transform-rotate-x-hover, var(--cmsmasters-transform-rotate-x))) rotateY(var(--cmsmasters-transform-rotate-y-hover, var(--cmsmasters-transform-rotate-y))) scale(var(--cmsmasters-transform-scale-x-hover, var(--cmsmasters-transform-scale-x)), var(--cmsmasters-transform-scale-y-hover, var(--cmsmasters-transform-scale-y))) skew(var(--cmsmasters-transform-skew-x-hover, var(--cmsmasters-transform-skew-x)), var(--cmsmasters-transform-skew-y-hover, var(--cmsmasters-transform-skew-y))); opacity: var(--cmsmasters-transform-opacity-hover, var(--cmsmasters-transform-opacity)); backdrop-filter: blur(var(--cmsmasters-transform-blur-hover, var(--cmsmasters-transform-blur)));"}`;

function renderSlide(pkg: any, index: number, isDuplicate: boolean): string {
	const slideClass = isDuplicate ? 'swiper-slide swiper-slide-duplicate' : 'swiper-slide';
	const postId = `about-pkg-${isDuplicate ? 'd' : ''}${index}`;
	const bgCss = `.${postId} .elementor-element.elementor-element-36e66642:not(.elementor-motion-effects-element-type-background):not(.cmsmasters-bg-effect), .${postId} .elementor-element.elementor-element-36e66642 > .elementor-motion-effects-container > .elementor-motion-effects-layer, .${postId} .elementor-element.elementor-element-36e66642 > .cmsmasters-bg-effects-container > .cmsmasters-bg-effects-element{background-image:url("${pkg.bg_image_url}");}`;
	const titleEscaped = pkg.title.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
	const descriptionEscaped = pkg.description.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
	const excerptText = pkg.excerpt || '';

	return `<div class="${slideClass}" data-swiper-slide-index="${index}" style="width: 297px; margin-right: 30px;" role="group" aria-label="${index + 1} / ${totalSlides}"><article id="${postId}" class="cmsmasters-blog__post ${postId} type-services status-publish has-post-thumbnail hentry"><div class="cmsmasters-blog__post-inner"><style>${bgCss}</style><div data-elementor-type="cmsmasters_entry" data-elementor-id="126" class="elementor elementor-126" data-elementor-title="Entry"><div class="elementor-inner">
				<div class="elementor-section-wrap">
					<div class="elementor-element elementor-element-36e66642 e-con-full cmsms_container_for_transform_hover_effect e-flex cmsmasters-bg-hide-none cmsmasters-bg-hide-none cmsmasters-block-default e-con e-parent" data-id="36e66642" data-element_type="container" data-settings='{"background_background":"classic"}'>
		<div class="elementor-element elementor-element-658dc249 e-con-full cmsmasters-effect-hover-type-section cmsmasters-effect cmsmasters-effect-type-transform e-flex cmsmasters-block-default e-con e-child" data-id="658dc249" data-element_type="container" data-settings='${hoverSettings658}'>
		<div class="elementor-element elementor-element-4d04107a e-con-full cmsmasters-effect cmsmasters-effect-type-transform cmsmasters-effect-hover-type-section e-flex cmsmasters-block-default e-con e-child" data-id="4d04107a" data-element_type="container" data-settings='${hoverSettings4d0}'>
				<div class="elementor-element elementor-element-408aef87 elementor-widget__width-inherit cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-image" data-id="408aef87" data-element_type="widget" data-widget_type="image.default">
				<div class="elementor-widget-container">
															<img src="${pkg.icon_url}" title="" alt="" loading="lazy">															</div>
				</div>
				<div class="elementor-element elementor-element-15f70d0f cmsmasters-line-clamp-yes cmsmasters-color-variation-default cmsmasters-pointer-none cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-post-title cmsmasters-widget-title" data-id="15f70d0f" data-element_type="widget" data-widget_type="cmsmasters-post-title.default">
				<div class="elementor-widget-container">
					<h3 class="entry-title cmsmasters-widget-title__heading" title="${titleEscaped}"><a href="${pkg.url}">${pkg.title}</a></h3>				</div>
				</div>
				<div class="elementor-element elementor-element-8b1eabe cmsmasters-line-clamp-yes cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-post-excerpt cmsmasters-widget-short-text" data-id="8b1eabe" data-element_type="widget" data-widget_type="cmsmasters-post-excerpt.default">
				<div class="elementor-widget-container">
					<div class="entry-content"><p>${excerptText}</p>
</div>				</div>
				</div>
				<div class="elementor-element elementor-element-338c09ae cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-heading" data-id="338c09ae" data-element_type="widget" data-widget_type="heading.default">
				<div class="elementor-widget-container">
					<h2 class="elementor-heading-title elementor-size-default">${descriptionEscaped}</h2>				</div>
				</div>
				<div class="elementor-element elementor-element-7c3aaad9 cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-button" data-id="7c3aaad9" data-element_type="widget" data-widget_type="cmsmasters-button.default">
				<div class="elementor-widget-container">
					<div class="elementor-widget-cmsmasters-button__button-container"><div class="elementor-widget-cmsmasters-button__button-container-inner"><a href="${pkg.url}" class="cmsmasters-button-link elementor-widget-cmsmasters-button__button cmsmasters-icon-view- cmsmasters-icon-shape- cmsmasters-button-size-sm" role="button" tabindex="0"><span class="elementor-widget-cmsmasters-button__content-wrapper cmsmasters-align-icon-"><span class="elementor-widget-cmsmasters-button__text">Read More</span></span></a></div></div>				</div>
				</div>
				</div>
				</div>
		<div class="elementor-element elementor-element-1e5ddaf5 e-con-full cmsmasters-effect cmsmasters-effect-type-transform cmsmasters-effect-hover-type-section e-flex cmsmasters-block-default e-con e-child" data-id="1e5ddaf5" data-element_type="container" data-settings='${overlaySettings}'>
				</div>
		<div class="elementor-element elementor-element-5d7de6a9 e-con-full cmsmasters-effect cmsmasters-effect-type-transform cmsmasters-effect-hover-type-section e-flex cmsmasters-block-default e-con e-child" data-id="5d7de6a9" data-element_type="container" data-settings='${overlaySettings}'>
				</div>
				</div>
						</div>
			</div>
		</div></div></article></div>`;
}

// Generate all slides: duplicate set + real set + duplicate set
let allSlidesHtml = '';
// Duplicate slides (beginning)
for (let i = 0; i < packages.length; i++) {
	allSlidesHtml += renderSlide(packages[i], i, true);
}
// Real slides
for (let i = 0; i < packages.length; i++) {
	allSlidesHtml += renderSlide(packages[i], i, false);
}
// Duplicate slides (end)
for (let i = 0; i < packages.length; i++) {
	allSlidesHtml += renderSlide(packages[i], i, true);
}

// Pagination bullets
let paginationHtml = '';
for (let i = 0; i < packages.length; i++) {
	const isActive = i === 3 ? ' swiper-pagination-bullet-active' : '';
	const ariaCurrent = i === 3 ? ' aria-current="true"' : '';
	paginationHtml += `<span class="swiper-pagination-bullet${isActive}" tabindex="0" role="button" aria-label="Go to slide ${i + 1}"${ariaCurrent}></span>`;
}
