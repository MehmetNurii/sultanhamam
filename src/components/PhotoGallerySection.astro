---
import { getPageSection } from "../lib/supabase";

const section = await getPageSection("index", "gallery");

// Eğer section görünür değilse, hiçbir şey render etme
if (!section || !section.visible) {
	return null;
}

const title = section?.title || "Photo Gallery";
const subtitle =
	section?.subtitle || "A visual journey of mind and body harmony";

// Gallery image URL'lerini extra_data'dan çek
const defaultGalleryImages = [
	"/assets/light/wp-content/uploads/sites/4/2025/04/61-home-2-5.webp",
	"/assets/light/wp-content/uploads/sites/4/2025/04/61-home-2-6.webp",
	"/assets/light/wp-content/uploads/sites/4/2025/04/61-home-2-7.webp",
	"/assets/light/wp-content/uploads/sites/4/2025/04/61-home-2-8.webp",
	"/assets/light/wp-content/uploads/sites/4/2025/04/61-home-2-9.webp"
];

const galleryImages = section?.extra_data?.gallery_images || defaultGalleryImages;

// Helper function: Image URL'den srcset oluştur
function getImageSrcset(baseUrl: string): string {
	// URL'nin sonundaki .webp'yi kaldır
	const basePath = baseUrl.endsWith('.webp') ? baseUrl.slice(0, -5) : baseUrl;
	return `${basePath}-1024x580.webp 1024w, ${basePath}-300x170.webp 300w, ${basePath}-768x435.webp 768w, ${basePath}-530x300.webp 530w, ${basePath}-600x340.webp 600w, ${basePath}.webp 1180w`;
}

function getImageSrc(baseUrl: string): string {
	// URL'nin sonundaki .webp'yi kaldır, sonra -1024x580.webp ekle
	const basePath = baseUrl.endsWith('.webp') ? baseUrl.slice(0, -5) : baseUrl;
	return `${basePath}-1024x580.webp`;
}
---

<section
	class="elementor-element elementor-element-44656dd e-con-full e-flex cmsmasters-block-default e-con e-parent"
	data-id="44656dd"
	data-element_type="container"
>
	<div
		class="elementor-element elementor-element-eabc1ea e-flex e-con-boxed cmsmasters-block-default e-con e-child"
		data-id="eabc1ea"
		data-element_type="container"
	>
		<div class="e-con-inner">
			<div
				class="elementor-element elementor-element-34a5eb8 cmsmasters-color-variation-gradient cmsmasters-line-clamp-no cmsmasters-color-gradient-linear cmsmasters-pointer-none cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-title cmsmasters-widget-title"
				data-id="34a5eb8"
				data-element_type="widget"
				data-settings='{"_animation":"fadeIn"}'
				data-widget_type="cmsmasters-title.default"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<h2 class="cmsmasters-widget-title__heading">
						<span class="title-inner-element">{title}</span>
					</h2>
				</div>
			</div>
			<div
				class="elementor-element elementor-element-7786e5b cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-heading"
				data-id="7786e5b"
				data-element_type="widget"
				data-settings='{"_animation":"fadeIn","_animation_delay":250}'
				data-widget_type="heading.default"
				style="visibility: visible; opacity: 1;"
			>
				<div class="elementor-widget-container">
					<h3 class="elementor-heading-title elementor-size-default">
						{subtitle}
					</h3>
				</div>
			</div>
		</div>
	</div>
	<div
		class="elementor-element elementor-element-7ec54a1 elementor-widget__width-initial cmsmasters-slider--effect-slide cmsmasters-slider--slider-direction-horizontal cmsmasters-media-carousel__image-fit-cover cmsmasters-block-default cmsmasters-sticky-default elementor-widget elementor-widget-cmsmasters-media-carousel e-widget-swiper"
		data-id="7ec54a1"
		data-element_type="widget"
		data-settings='{"slider_free_mode":"yes","slider_navigation":"bullets","slider_space_between":{"unit":"px","size":90,"sizes":[]},"slider_width":{"unit":"%","size":100,"sizes":[]},"slider_per_view_tablet":"1","_animation":"fadeInRight","_animation_delay":200,"slider_space_between_mobile":{"unit":"px","size":20,"sizes":[]},"slider_type":"carousel","slider_effect":"slide","slider_direction":"horizontal","slider_height_type":"auto","slider_per_view":"3","ytb_fs":"yes","facebook_fs":"yes","twitch_fs":"yes","hosted_fs":"yes","aspect_ratio":"169","slider_autoplay":"yes","slider_autoplay_speed":5000,"slider_speed":500,"slider_pause_on_hover":"yes","slider_infinite":"yes","slider_space_between_widescreen":{"unit":"px","size":"","sizes":[]},"slider_space_between_tablet":{"unit":"px","size":"","sizes":[]},"slider_width_widescreen":{"unit":"px","size":"","sizes":[]},"slider_width_tablet":{"unit":"px","size":"","sizes":[]},"slider_width_mobile":{"unit":"px","size":"","sizes":[]},"slider_scrollbar_circle":"circle"}'
		data-widget_type="cmsmasters-media-carousel.default"
		style="visibility: visible; opacity: 1;"
	>
		<div class="elementor-widget-container">
			<div
				id="cmsmasters-slider-7ec54a1"
				class="cmsmasters-slider cmsmasters-slider--init cmsmasters-slider--dir-horizontal cmsmasters-slider--effect-slide cmsmasters-slider--nav cmsmasters-slider--nav-bullets cmsmasters-slider-per-view-3"
			>
				<div
					class="swiper cmsmasters-swiper-container swiper-initialized swiper-horizontal swiper-pointer-events swiper-free-mode swiper-autoheight"
				>
					<div
						class="swiper-wrapper"
						style="cursor: grab; transform: translate3d(-5586px, 0px, 0px); height: 401px; transition-duration: 500ms;"
						id="swiper-wrapper-ecfd2210d2d2afedd"
						aria-live="off"
					>
						{/* Main slides */}
						{galleryImages.map((imageUrl: string, index: number) => {
							const imgSrc = getImageSrc(imageUrl);
							const imgSrcset = getImageSrcset(imageUrl);
							const imgHref = imageUrl;
							
							return (
								<div
									class="swiper-slide"
									data-swiper-slide-index={index}
									style="width: 708px; margin-right: 90px;"
									role="group"
									aria-label={`${index + 1} / ${galleryImages.length}`}
								>
									<figure
										class="elementor-widget-cmsmasters-media-carousel__wrapper"
									>
										<a
											class="elementor-widget-cmsmasters-media-carousel__outer"
											href={imgHref}
											data-elementor-open-lightbox="yes"
											data-elementor-lightbox-slideshow="7ec54a1"
											aria-label="Image lightbox open"
										>
											<div
												class="elementor-widget-cmsmasters-media-carousel__inner"
											>
												<img
													loading="lazy"
													decoding="async"
													width="1024"
													height="580"
													src={imgSrc}
													class="attachment-large size-large"
													alt=""
													srcset={imgSrcset}
													sizes="(max-width: 1024px) 100vw, 1024px"
												/>
											</div>
										</a>
									</figure>
								</div>
							);
						})}
					</div><span
						class="swiper-notification"
						aria-live="assertive"
						aria-atomic="true"></span>
				</div><div class="swiper-pagination-wrap">
					<div class="swiper-pagination-outer">
						<div
							class="swiper-pagination swiper-pagination-clickable swiper-pagination-bullets swiper-pagination-horizontal"
						>
							<span
								class="swiper-pagination-bullet"
								tabindex="0"
								role="button"
								aria-label="Go to slide 1"></span><span
								class="swiper-pagination-bullet"
								tabindex="0"
								role="button"
								aria-label="Go to slide 2"></span><span
								class="swiper-pagination-bullet swiper-pagination-bullet-active"
								tabindex="0"
								role="button"
								aria-label="Go to slide 3"
								aria-current="true"></span><span
								class="swiper-pagination-bullet"
								tabindex="0"
								role="button"
								aria-label="Go to slide 4"></span><span
								class="swiper-pagination-bullet"
								tabindex="0"
								role="button"
								aria-label="Go to slide 5"></span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
