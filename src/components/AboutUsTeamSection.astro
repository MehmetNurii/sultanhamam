];

const teamMembers = (section?.extra_data as any)?.team_members || defaultTeamMembers;

const facebookSvg = '<svg aria-hidden="true" class="e-font-icon-svg e-fab-facebook-f" viewBox="0 0 320 512" xmlns="http://www.w3.org/2000/svg"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"></path></svg>';
const twitterSvg = '<svg aria-hidden="true" class="e-font-icon-svg e-fab-x-twitter" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"></path></svg>';
const linkedinSvg = '<svg aria-hidden="true" class="e-font-icon-svg e-fab-linkedin-in" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path></svg>';

function renderSocialIcons(social: any): string {
	let html = '<div class="elementor-social-icons-wrapper elementor-grid" role="list">';
	if (social?.facebook) {
		html += `<span class="elementor-grid-item" role="listitem"><a class="elementor-icon elementor-social-icon elementor-social-icon-facebook-f elementor-repeater-item-4077099" href="${social.facebook}" target="_blank"><span class="elementor-screen-only">Facebook-f</span>${facebookSvg}</a></span>`;
	}
	if (social?.twitter) {
		html += `<span class="elementor-grid-item" role="listitem"><a class="elementor-icon elementor-social-icon elementor-social-icon-x-twitter elementor-repeater-item-c1137f7" href="${social.twitter}" target="_blank"><span class="elementor-screen-only">X-twitter</span>${twitterSvg}</a></span>`;
	}
	if (social?.linkedin) {
		html += `<span class="elementor-grid-item" role="listitem"><a class="elementor-icon elementor-social-icon elementor-social-icon-linkedin-in elementor-repeater-item-d6e9e58" href="${social.linkedin}" target="_blank"><span class="elementor-screen-only">Linkedin-in</span>${linkedinSvg}</a></span>`;
	}
	html += '</div>';
	return html;
}
