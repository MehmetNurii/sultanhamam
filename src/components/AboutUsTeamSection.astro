import { getPageSection } from '../lib/supabase';

const section = await getPageSection('about-us', 'team');

const subtitle = section?.subtitle || 'MEET OUR TEAM';
const title = section?.title || 'Empowering You Through Mindful Wellness';
const buttonText = section?.button_text || 'Meet the Team';
const buttonUrl = section?.button_url || '/our-team/';

const defaultTeamMembers = [
	{
		name: 'Angela Carbone',
		role: 'Soft Tissue Therapist',
		image_url: '/assets/light/wp-content/uploads/sites/4/2025/04/61-profile-1.webp',
		profile_url: 'https://wellness-bliss.cmsmasters.studio/light/cmsms_profile/angela-carbone/',
